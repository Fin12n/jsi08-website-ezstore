<%
const pendingCount = typeof pendingApplications !== 'undefined' ? pendingApplications.length : 0;
const sellerCount = typeof sellers !== 'undefined' ? sellers.length : 0;
const isTabPending = typeof activeTab !== 'undefined' && activeTab === 'pending';

const sellersRows = typeof sellers !== 'undefined' && sellers.length > 0
  ? sellers.map(s => {
      const initials = (s.displayName || s.email || 'S').charAt(0).toUpperCase();
      return '<tr>' +
        '<td><div style="display:flex;align-items:center;gap:10px;">' +
          '<div style="width:36px;height:36px;border-radius:50%;background:linear-gradient(135deg,#10b981,#3b82f6);display:flex;align-items:center;justify-content:center;font-size:13px;font-weight:700;color:white;">' + initials + '</div>' +
          '<div><div style="font-weight:600;color:var(--text-primary);font-size:13px;">' + (s.displayName || s.email) + '</div>' +
          '<div style="font-size:11px;color:var(--text-muted);">' + (s.email || '') + '</div></div>' +
        '</div></td>' +
        '<td style="font-weight:600;color:var(--success);">--</td>' +
        '<td>--</td>' +
        '<td style="font-size:12px;color:var(--text-muted);">' + (s.sellerSince ? new Date(s.sellerSince).toLocaleDateString('vi-VN') : '--') + '</td>' +
        '<td><span class="badge badge-success"><i class="fas fa-circle"></i> Hoạt động</span></td>' +
        '<td><div style="display:flex;gap:6px;">' +
          '<button onclick="viewBankInfo(\'' + s.id + '\')" class="btn btn-ghost btn-sm" title="Xem thông tin ngân hàng"><i class="fas fa-building-columns"></i></button>' +
          '<button onclick="document.getElementById(\'ban-form-' + s.id + '\').submit()" class="btn btn-danger btn-sm" title="Cấm Seller"><i class="fas fa-ban"></i></button>' +
          '<form id="ban-form-' + s.id + '" action="/admin/sellers/' + s.id + '/ban" method="POST" style="display:none"></form>' +
        '</div></td>' +
      '</tr>';
    }).join('')
  : '<tr><td colspan="6" style="text-align:center;padding:30px;color:var(--text-muted);">Chưa có Seller nào.</td></tr>';

const pendingAppsHtml = typeof pendingApplications !== 'undefined' && pendingApplications.length > 0
  ? pendingApplications.map(app => {
      return '<div class="card" style="margin-bottom:16px;border-left:3px solid var(--warning);">' +
        '<div style="display:flex;align-items:flex-start;justify-content:space-between;gap:16px;">' +
          '<div>' +
            '<div style="font-weight:700;color:var(--text-primary);font-size:15px;margin-bottom:4px;">' + (app.shopName || app.displayName || 'Không có tên') + '</div>' +
            '<div style="font-size:13px;color:var(--text-secondary);margin-bottom:6px;">' + (app.email || 'N/A') + '</div>' +
            '<div style="font-size:12px;color:var(--text-muted);line-height:1.6;max-width:500px;">' + (app.description || 'Không có mô tả.') + '</div>' +
          '</div>' +
          '<div style="display:flex;flex-direction:column;gap:8px;flex-shrink:0;">' +
            '<form action="/admin/sellers/' + app.id + '/approve" method="POST"><button type="submit" class="btn btn-success btn-sm"><i class="fas fa-check"></i> Duyệt</button></form>' +
            '<button onclick="rejectApp(\'' + app.id + '\')" class="btn btn-danger btn-sm"><i class="fas fa-times"></i> Từ chối</button>' +
          '</div>' +
        '</div>' +
        '<div style="margin-top:12px;display:flex;gap:16px;font-size:12px;color:var(--text-muted);">' +
          '<span><i class="fas fa-calendar"></i> Nộp: ' + (app.createdAt ? new Date(app.createdAt).toLocaleDateString('vi-VN') : '--') + '</span>' +
          '<span><i class="fas fa-tag"></i> Danh mục: ' + (app.category || 'Chưa xác định') + '</span>' +
        '</div>' +
      '</div>';
    }).join('')
  : '<div class="card" style="text-align:center;padding:40px;color:var(--text-muted);"><i class="fas fa-check-circle" style="font-size:32px;opacity:0.3;margin-bottom:10px;display:block;"></i>Tất cả đơn đăng ký đã được xử lý!</div>';

const sellersHtml = `
<div class="page-header">
  <div style="display:flex;align-items:center;justify-content:space-between;">
    <div>
      <div class="page-title">🏪 Quản lý Người bán</div>
      <div class="page-subtitle">Duyệt đơn đăng ký Seller mới và quản lý người bán hiện tại.</div>
    </div>
    ${pendingCount > 0 ? '<div style="background:rgba(245,158,11,0.1);border:1px solid rgba(245,158,11,0.3);border-radius:var(--radius-sm);padding:10px 16px;display:flex;align-items:center;gap:10px;"><i class="fas fa-bell" style="color:var(--warning);"></i><span style="color:var(--warning);font-weight:600;font-size:13px;">' + pendingCount + ' đơn chờ duyệt!</span></div>' : ''}
  </div>
</div>

<!-- TABS -->
<div class="tabs">
  <button class="tab-btn ${!isTabPending ? 'active' : ''}" onclick="switchTab('active')">
    <i class="fas fa-store"></i> Seller hiện tại
    <span style="background:var(--accent-glow);color:var(--accent-light);padding:1px 7px;border-radius:10px;font-size:11px;">${sellerCount}</span>
  </button>
  <button class="tab-btn ${isTabPending ? 'active' : ''}" onclick="switchTab('pending')">
    <i class="fas fa-clock"></i> Đơn đăng ký chờ duyệt
    ${pendingCount > 0 ? '<span style="background:rgba(245,158,11,0.2);color:var(--warning);padding:1px 7px;border-radius:10px;font-size:11px;">' + pendingCount + '</span>' : ''}
  </button>
</div>

<!-- ACTIVE SELLERS TAB -->
<div id="tab-active" class="card" style="${isTabPending ? 'display:none' : ''}">
  <div class="table-wrap">
    <table>
      <thead>
        <tr>
          <th>Người bán</th><th>Doanh số</th><th>Sản phẩm</th><th>Gia nhập</th><th>Trạng thái</th><th>Thao tác</th>
        </tr>
      </thead>
      <tbody>${sellersRows}</tbody>
    </table>
  </div>
</div>

<!-- PENDING APPLICATIONS TAB -->
<div id="tab-pending" style="${!isTabPending ? 'display:none' : ''}">
  ${pendingAppsHtml}
</div>
`;

const extraScript = `<script>
function switchTab(tab) {
  document.querySelectorAll('.tab-btn').forEach(function(b,i){ b.classList.toggle('active', (i === 0 && tab === 'active') || (i === 1 && tab === 'pending')); });
  document.getElementById('tab-active').style.display = tab === 'active' ? '' : 'none';
  document.getElementById('tab-pending').style.display = tab === 'pending' ? '' : 'none';
}

function rejectApp(appId) {
  var reason = prompt('Nhập lý do từ chối:');
  if (!reason) return;
  var form = document.createElement('form');
  form.method = 'POST'; form.action = '/admin/sellers/' + appId + '/reject';
  var field = document.createElement('input');
  field.type = 'hidden'; field.name = 'rejectionReason'; field.value = reason;
  form.appendChild(field); document.body.appendChild(form); form.submit();
}

async function viewBankInfo(sellerId) {
  var res = await fetch('/admin/sellers/' + sellerId + '/bank-info');
  var data = await res.json();
  if (data.success) {
    var info = data.bankInfo;
    if (info) {
      alert('Thông tin ngân hàng:\\nNgân hàng: ' + (info.bankName || '--') + '\\nTên TK: ' + (info.accountName || '--') + '\\nSố TK: ' + (info.accountNumber || '--'));
    } else {
      alert('Người bán chưa cập nhật thông tin ngân hàng.');
    }
  }
}
<\/script>`;
%>
<%- include('./layout', { body: sellersHtml, extraScript }) %>
