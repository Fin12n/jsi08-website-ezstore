        '</template>' +
        '<template x-if="versions.length > 0">' +
          '<div style="display:flex;flex-direction:column;gap:10px;max-height:420px;overflow-y:auto;padding-right:4px;">' +
            '<template x-for="v in versions" :key="v.fileKey + v.version">' +
              '<div style="background:rgba(255,255,255,0.015);border:1px solid var(--border);border-radius:10px;padding:14px;display:flex;align-items:center;justify-content:space-between;gap:12px;">' +
                '<div style="flex-grow:1;display:flex;flex-direction:column;gap:3px;">' +
                  '<div style="display:flex;align-items:center;gap:8px;">' +
                    '<span style="font-size:13px;font-weight:700;color:var(--text-primary);background:rgba(99,102,241,0.15);color:var(--accent-light);padding:2px 8px;border-radius:6px;" x-text="v.version"></span>' +
                    '<span style="font-size:11px;color:var(--text-muted);" x-text="new Date(v.uploadedAt).toLocaleDateString(\'vi-VN\')"></span>' +
                  '</div>' +
                  '<div style="font-size:12px;color:var(--text-secondary);font-weight:500;" x-text="v.fileName + \' (\' + Math.round(v.fileSize / 1024) + \' KB)\'"></div>' +
                  '<div x-show="v.changelog" style="font-size:11px;color:var(--text-muted);font-style:italic;margin-top:2px;" x-text="\'Changelog: \' + v.changelog"></div>' +
                '</div>' +
                '<button type="button" @click="deleteVersion(v.fileKey, v.version)" :disabled="deletingKeys.includes(v.fileKey + \'-\' + v.version)" style="background:rgba(244,63,94,0.1);border:1px solid rgba(244,63,94,0.15);border-radius:8px;color:var(--danger);padding:8px 10px;cursor:pointer;font-size:12px;display:inline-flex;align-items:center;gap:4px;" onmouseover="this.style.background=\'rgba(244,63,94,0.2)\'" onmouseout="this.style.background=\'rgba(244,63,94,0.1)\'">' +
                  '<template x-if="!deletingKeys.includes(v.fileKey + \'-\' + v.version)">' +
                    '<span><i class="fa-solid fa-trash-can"></i> Xóa</span>' +
                  '</template>' +
                  '<template x-if="deletingKeys.includes(v.fileKey + \'-\' + v.version)">' +
                    '<span><i class="fas fa-spinner fa-spin"></i></span>' +
                  '</template>' +
                '</button>' +
              '</div>' +
            '</template>' +
          '</div>' +
        '</template>' +
      '</div>' +

    '</div>' +
  '</div>' +
  '</form>';

const extraScript =
  '<script src="https://cdn.jsdelivr.net/npm/quill@2.0.2/dist/quill.js"></sc' + 'ript>' +
  '<script>' +
  '  document.addEventListener("alpine:init", () => {' +
  '    Alpine.data("editProductForm", () => ({' +
  '      activeZone: "gallery",' +
  '      thumbnailData: "' + safeImage + '",' +
  '      existingGallery: ' + existingGalleryJson + ',' +
  '      gallery: [],' +
  '      versions: ' + productVersionsJson + ',' +
  '      newVer: "",' +
  '      newChangelog: "",' +
  '      uploadProgress: 0,' +
  '      isUploading: false,' +
  '      uploadedFileKey: "",' +
  '      uploadedFileName: "",' +
  '      uploadedFileSize: 0,' +
  '      isSavingProduct: false,' +
  '      isPublishingVersion: false,' +
  '      deletingKeys: [],' +
  '      compressAndAdd(file, target) {' +
  '        if (!file || !file.type.startsWith("image/")) return;' +
  '        const reader = new FileReader();' +
  '        reader.onload = (e) => {' +
  '          const img = new Image();' +
  '          img.onload = () => {' +
  '            const canvas = document.createElement("canvas");' +
  '            let width = img.width;' +
  '            let height = img.height;' +
  '            const MAX_WIDTH = 1200;' +
  '            const MAX_HEIGHT = 1200;' +
  '            if (width > height) {' +
  '              if (width > MAX_WIDTH) { height *= MAX_WIDTH / width; width = MAX_WIDTH; }' +
  '            } else {' +
  '              if (height > MAX_HEIGHT) { width *= MAX_HEIGHT / height; height = MAX_HEIGHT; }' +
  '            }' +
  '            canvas.width = width;' +
  '            canvas.height = height;' +
  '            const ctx = canvas.getContext("2d");' +
  '            ctx.drawImage(img, 0, 0, width, height);' +
  '            const dataUrl = canvas.toDataURL("image/jpeg", 0.75);' +
  '            if (target === "thumbnail") {' +
  '              this.thumbnailData = dataUrl;' +
  '            } else {' +
  '              this.gallery.push({ id: Date.now() + Math.random(), data: dataUrl });' +
  '            }' +
  '          };' +
  '          img.src = e.target.result;' +
  '        };' +
  '        reader.readAsDataURL(file);' +
  '      },' +
  '      addFiles(files, target) {' +
  '        const dest = target || this.activeZone;' +
  '        if (dest === "thumbnail") {' +
  '          const file = files[0];' +
  '          this.compressAndAdd(file, "thumbnail");' +
  '        } else {' +
  '          for (let i = 0; i < files.length; i++) {' +
  '            this.compressAndAdd(files[i], "gallery");' +
  '          }' +
  '        }' +
  '      },' +
  '      removeImage(id) { this.gallery = this.gallery.filter(item => item.id !== id); },' +
  '      removeExisting(url) { this.existingGallery = this.existingGallery.filter(u => u !== url); },' +
  '      async triggerVersionUpload(e) {' +
  '        const file = e.target.files[0];' +
  '        if (!file) return;' +
  '        this.isUploading = true;' +
  '        this.uploadProgress = 0;' +
  '        try {' +
  '          const res = await fetch("/admin/api/presign", {' +
  '            method: "POST",' +
  '            headers: { "Content-Type": "application/json" },' +
  '            body: JSON.stringify({ fileName: file.name, fileType: file.type, productId: "' + productId + '" })' +
  '          });' +
  '          const data = await res.json();' +
  '          if (data.error) throw new Error(data.error);' +
  '          if (data.isLocal) {' +
  '            const formData = new FormData();' +
  '            formData.append("file", file);' +
  '            const xhr = new XMLHttpRequest();' +
  '            xhr.open("POST", data.uploadUrl, true);' +
  '            xhr.upload.onprogress = (event) => {' +
  '              if (event.lengthComputable) {' +
  '                this.uploadProgress = Math.round((event.loaded / event.total) * 100);' +
  '              }' +
  '            };' +
  '            xhr.onload = () => {' +
  '              if (xhr.status === 200) {' +
  '                const resData = JSON.parse(xhr.responseText);' +
  '                this.uploadedFileKey = resData.fileKey;' +
  '                this.uploadedFileName = resData.fileName;' +
  '                this.uploadedFileSize = resData.fileSize;' +
  '                this.isUploading = false;' +
  '                this.uploadProgress = 100;' +
  '                Notifier.success("Tải tệp tin lên máy chủ thành công!");' +
  '              } else {' +
  '                this.isUploading = false;' +
  '                Notifier.error("Upload cục bộ thất bại: " + xhr.statusText);' +
  '              }' +
  '            };' +
  '            xhr.onerror = () => {' +
  '              this.isUploading = false;' +
  '              Notifier.error("Lỗi kết nối khi tải lên server cục bộ");' +
  '            };' +
  '            xhr.send(formData);' +
  '          } else {' +
  '            const xhr = new XMLHttpRequest();' +
  '            xhr.open("PUT", data.uploadUrl, true);' +
  '            xhr.setRequestHeader("Content-Type", file.type);' +
  '            xhr.upload.onprogress = (event) => {' +
  '              if (event.lengthComputable) {' +
  '                this.uploadProgress = Math.round((event.loaded / event.total) * 100);' +
  '              }' +
  '            };' +
  '            xhr.onload = () => {' +
  '              if (xhr.status === 200) {' +
  '                this.uploadedFileKey = data.fileKey;' +
  '                this.uploadedFileName = file.name;' +
  '                this.uploadedFileSize = file.size;' +
  '                this.isUploading = false;' +
  '                this.uploadProgress = 100;' +
  '                Notifier.success("Tải tệp tin lên Cloudflare R2 thành công!");' +
  '              } else {' +
  '                this.isUploading = false;' +
  '                Notifier.error("Upload thất bại: " + xhr.statusText);' +
  '              }' +
  '            };' +
  '            xhr.onerror = () => {' +
  '              this.isUploading = false;' +
  '              Notifier.error("Lỗi kết nối khi tải lên Cloudflare R2");' +
  '            };' +
  '            xhr.send(file);' +
  '          }' +
  '        } catch (err) {' +
  '          this.isUploading = false;' +
  '          Notifier.error("Lỗi: " + err.message);' +
  '        }' +
  '      },' +
  '      async saveNewVersion() {' +
  '        if (!this.newVer || !this.uploadedFileKey) {' +
  '          Notifier.warning("Vui lòng điền số phiên bản và upload tệp tin!");' +
  '          return;' +
  '        }' +
  '        this.isPublishingVersion = true;' +
  '        try {' +
  '          const res = await fetch("/admin/api/products/' + productId + '/versions", {' +
  '            method: "POST",' +
  '            headers: { "Content-Type": "application/json" },' +
  '            body: JSON.stringify({' +
  '              version: this.newVer,' +
  '              changelog: this.newChangelog,' +
  '              fileKey: this.uploadedFileKey,' +
  '              fileName: this.uploadedFileName,' +
  '              fileSize: this.uploadedFileSize' +
  '            })' +
  '          });' +
  '          const data = await res.json();' +
  '          if (data.error) throw new Error(data.error);' +
  '          this.versions.unshift(data.version);' +
  '          this.newVer = "";' +
  '          this.newChangelog = "";' +
  '          this.uploadedFileKey = "";' +
  '          this.uploadedFileName = "";' +
  '          this.uploadedFileSize = 0;' +
  '          this.uploadProgress = 0;' +
  '          Notifier.success("Đã phát hành phiên bản mới!");' +
  '        } catch (err) {' +
  '          Notifier.error("Lỗi khi lưu: " + err.message);' +
  '        } finally {' +
  '          this.isPublishingVersion = false;' +
  '        }' +
  '      },' +
  '      async deleteVersion(fileKey, versionStr) {' +
  '        const isConfirmed = await Notifier.confirm("Bạn có chắc muốn xóa phiên bản " + versionStr + "?", "Xác nhận xóa", "Xóa", "Hủy");' +
  '        if (!isConfirmed) return;' +
  '        const targetKey = fileKey + "-" + versionStr;' +
  '        this.deletingKeys.push(targetKey);' +
  '        try {' +
  '          const res = await fetch("/admin/api/products/' + productId + '/versions/delete", {' +
  '            method: "POST",' +
  '            headers: { "Content-Type": "application/json" },' +
  '            body: JSON.stringify({ fileKey: fileKey, version: versionStr })' +
  '          });' +
  '          const data = await res.json();' +
  '          if (data.error) throw new Error(data.error);' +
  '          this.versions = this.versions.filter(v => !(v.fileKey === fileKey && v.version === versionStr));' +
  '          Notifier.success("Đã xóa phiên bản thành công!");' +
  '        } catch (err) {' +
  '          Notifier.error("Lỗi khi xóa: " + err.message);' +
  '        } finally {' +
  '          this.deletingKeys = this.deletingKeys.filter(k => k !== targetKey);' +
  '        }' +
  '      }' +
  '    }));' +
  '  });' +
  '  const categories = ' + categoriesJson + ';' +
  '  const product = ' + productJson + ';' +
  '  const currentCustomFields = product.customFields || {};' +
  '  function initProductsEdit() {' +
  '    const quill = new Quill("#editor-container", { theme:"snow", modules:{ toolbar:[[{header:[1,2,3,false]}],["bold","italic","underline","strike"],[{list:"ordered"},{list:"bullet"}],["link","clean"]] } });' +
  '    const selectEl = document.getElementById("category-select");' +
  '    const wrapper = document.getElementById("dynamic-fields-wrapper");' +
  '    const container = document.getElementById("dynamic-fields-container");' +
  '    if (!selectEl) return;' +
  '    function renderFields(slug) {' +
  '      const cat = categories.find(c => c.slug === slug);' +
  '      container.innerHTML = "";' +
  '      if (cat && cat.fields && cat.fields.length > 0) {' +
  '        wrapper.style.display = "block";' +
  '        cat.fields.forEach(f => {' +
  '          const reqAttr = f.required ? "required" : "";' +
  '          const reqStar = f.required ? \'<span style="color:var(--danger)">*</span>\' : "";' +
  '          const currentVal = currentCustomFields[f.name] !== undefined ? currentCustomFields[f.name] : "";' +
  '          const fs = "width:100%;padding:10px 14px;background:rgba(255,255,255,0.05);border:1px solid var(--border);border-radius:10px;color:var(--text-primary);font-size:13px;outline:none;";' +
  '          const ls = "font-size:12.5px;font-weight:600;color:var(--text-primary);margin-bottom:6px;display:block;";' +
  '          let h = "";' +
  '          if (f.type === "select") {' +
  '            const opts = (f.options||[]).map(o => \'<option value="\' + o + \'"\' + (String(o)===String(currentVal)?" selected":"") + \'>\' + o + "</option>").join("");' +
  '            h = \'<div style="display:flex;flex-direction:column;gap:4px;"><label style="\' + ls + \'">\' + f.name + " " + reqStar + \'</label><select name="customFields[\' + f.name + \']" style="\' + fs + \'" \' + reqAttr + \'><option value="">-- Chọn --</option>\' + opts + "</select></div>";' +
  '          } else if (f.type === "number") {' +
  '            h = \'<div style="display:flex;flex-direction:column;gap:4px;"><label style="\' + ls + \'">\' + f.name + " " + reqStar + \'</label><input type="number" name="customFields[\' + f.name + \']" style="\' + fs + \'" value="\' + currentVal + \'" \' + reqAttr + \'></div>\';' +
  '          } else {' +
  '            h = \'<div style="display:flex;flex-direction:column;gap:4px;"><label style="\' + ls + \'">\' + f.name + " " + reqStar + \'</label><input type="text" name="customFields[\' + f.name + \']" style="\' + fs + \'" value="\' + currentVal + \'" \' + reqAttr + \'></div>\';' +
  '          }' +
  '          container.insertAdjacentHTML("beforeend", h);' +
  '        });' +
  '      } else { wrapper.style.display = "none"; }' +
  '    }' +
  '    if (selectEl.value) renderFields(selectEl.value);' +
  '    selectEl.addEventListener("change", function() { renderFields(this.value); });' +
  '    document.getElementById("edit-product-form").addEventListener("submit", function() {' +
  '      document.getElementById("hidden-description").value = quill.getSemanticHTML();' +
  '    });' +
  '  }' +
  '  if (document.readyState==="loading") { document.addEventListener("DOMContentLoaded",initProductsEdit); } else { initProductsEdit(); }' +
  '</sc' + 'ript>';
%>
<%- include('./layout', { body: body, extraScript: extraScript }) %>
