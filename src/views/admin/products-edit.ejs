const fieldStyle = 'width:100%;padding:10px 14px;background:rgba(255,255,255,0.05);border:1px solid var(--border);border-radius:10px;color:var(--text-primary);font-size:13.5px;outline:none;';
const labelStyle = 'font-size:12.5px;font-weight:600;color:var(--text-primary);margin-bottom:6px;display:block;';
const cardStyle = 'background:linear-gradient(135deg,rgba(25,28,48,0.65),rgba(15,17,28,0.7));border-radius:16px;border:1px solid var(--border);';

