<%
// Pre-compute all server-side values BEFORE building any HTML string
// RULE: NEVER use backtick template literals containing HTML with class= inside EJS code blocks
//       Instead use plain string concatenation: '<div class="x">' + val + '</div>'
const origPriceNum = parseInt((product.originalPrice || '').replace(/[^0-9]/g, '')) || product.priceNumber || 0;
const catList = typeof categories !== 'undefined' ? categories : [];
const prod = typeof product !== 'undefined' ? product : {};
const productId = prod.docId || prod.id || '';
const safeTitle = (prod.title || '').replace(/"/g, '&quot;');
const safeFeatures = (prod.features || []).join(', ').replace(/"/g, '&quot;');
const safeItems = (prod.itemsList || []).join(', ').replace(/"/g, '&quot;');
const safePlugins = (prod.plugins || []).join(', ').replace(/"/g, '&quot;');
const safeGifts = (prod.gifts || []).join(', ').replace(/"/g, '&quot;');
const safeImage = (prod.image || '').replace(/\\/g, '\\\\').replace(/'/g, "\\'");
// Filter out any base64 data: URLs that may have leaked into Firestore — they'd cause 413 on Vercel
const galleryCleaned = Array.isArray(prod.carousel)
  ? prod.carousel.filter(u => u !== prod.image && u && !u.startsWith('data:'))
  : [];
const existingGalleryJson = JSON.stringify(galleryCleaned);
const productVersionsJson = JSON.stringify(prod.versions || []);

const categoriesJson = JSON.stringify(catList);
// Only serialize what's needed client-side (category + customFields for dynamic field rendering).
// Exclude heavy fields (description HTML, carousel URLs) to stay under Vercel's 4.5MB response limit.
const prodSlim = {
  category: prod.category || '',
  customFields: prod.customFields || {},
};
const productJson = JSON.stringify(prodSlim);


// Build category select options
let catOptions = '<option value="">-- Chọn danh mục --</option>';
catList.forEach(c => {
  catOptions += '<option value="' + c.slug + '"' + (c.slug === prod.category ? ' selected' : '') + '>' + c.name + '</option>';
});

