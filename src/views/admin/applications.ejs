<%- include('../partials/header') %>
<%- include('../partials/navbar') %>

<section class="admin-applications-section" style="padding-top: 100px; min-height: 80vh;">
  <div class="container">
    <div class="row g-4">
      <div class="col-lg-3">
        <div class="card glass-card p-4 sticky-top" style="top: 100px;">
          <!-- Sidebar -->
          <div class="text-center mb-4">
            <h5 class="text-white font-outfit mb-0"><i class="fa-solid fa-shield-halved text-danger me-2"></i>Admin Panel</h5>
          </div>
          <hr class="border-secondary opacity-25">
          <div class="nav flex-column nav-pills gap-2">
            <a href="/admin" class="nav-link text-white font-outfit"><i class="fa-solid fa-chart-line me-2"></i>Tổng quan</a>
            <a href="/admin/products" class="nav-link text-white font-outfit"><i class="fa-solid fa-box-open me-2"></i>Duyệt Sản phẩm</a>
            <a href="/admin/categories" class="nav-link text-white font-outfit"><i class="fa-solid fa-tags me-2"></i>Danh mục</a>
            <a href="/admin/applications" class="nav-link active font-outfit"><i class="fa-solid fa-id-card-clip me-2"></i>Duyệt Seller</a>
          </div>
        </div>
      </div>

      <div class="col-lg-9">
        <h3 class="text-white font-outfit mb-4">Duyệt yêu cầu làm Seller</h3>

        <div class="card glass-card p-0 overflow-hidden">
          <% if (applications && applications.length > 0) { %>
            <div class="table-responsive">
              <table class="table table-dark table-hover mb-0 bg-transparent align-middle">
                <thead>
                  <tr class="border-secondary border-opacity-25 text-secondary small text-uppercase">
                    <th class="py-3 px-4 bg-transparent border-0">User</th>
                    <th class="py-3 px-4 bg-transparent border-0">Bio</th>
                    <th class="py-3 px-4 bg-transparent border-0">Portfolio</th>
                    <th class="py-3 px-4 bg-transparent border-0 text-end">Hành động</th>
                  </tr>
                </thead>
                <tbody class="border-top-0">
                  <% applications.forEach(app => { %>
                    <tr class="border-secondary border-opacity-10">
                      <td class="px-4 py-3 bg-transparent text-white font-outfit fw-bold"><%= app.username %></td>
                      <td class="px-4 py-3 bg-transparent text-secondary small" style="max-width: 250px;"><%= app.bio %></td>
                      <td class="px-4 py-3 bg-transparent">
                        <% if (app.portfolio) { %>
                          <a href="<%= app.portfolio %>" target="_blank" class="btn btn-sm btn-outline-info">Xem link</a>
                        <% } else { %>
                          <span class="text-secondary small">Không có</span>
                        <% } %>
                      </td>
                      <td class="px-4 py-3 bg-transparent text-end">
                        <form action="/admin/applications/<%= app.id %>/approve" method="POST" class="d-inline">
                          <button type="submit" class="btn btn-sm btn-success"><i class="fa-solid fa-check"></i> Duyệt</button>
                        </form>
                        <form action="/admin/applications/<%= app.id %>/reject" method="POST" class="d-inline">
                          <button type="submit" class="btn btn-sm btn-danger"><i class="fa-solid fa-xmark"></i> Từ chối</button>
                        </form>
                      </td>
                    </tr>
                  <% }) %>
                </tbody>
              </table>
            </div>
          <% } else { %>
            <div class="p-5 text-center">
              <i class="fa-solid fa-clipboard-check text-secondary mb-3" style="font-size: 3rem; opacity: 0.5;"></i>
              <h5 class="text-white font-outfit">Không có yêu cầu nào đang chờ</h5>
            </div>
          <% } %>
        </div>
      </div>
    </div>
  </div>
</section>

<%- include('../partials/footer') %>
