<%
const categoriesHtml = `
<div class="page-header">
  <div class="page-title">📁 Quản lý Danh mục</div>
  <div class="page-subtitle">Thêm mới, chỉnh sửa và quản lý các danh mục sản phẩm trên hệ thống.</div>
</div>

<div style="display:grid; grid-template-columns: 2fr 1fr; gap: 24px; align-items: start;">
  
  <!-- Categories List -->
  <div class="card">
    <div class="card-title">
      <i class="fas fa-list text-primary"></i> Danh Sách Danh Mục
    </div>
    
    <div class="table-wrap">
      <table>
        <thead>
          <tr>
            <th>Slug</th>
            <th>Tên Danh Mục</th>
            <th>Mô tả</th>
            <th style="text-align: right;">Thao tác</th>
          </tr>
        </thead>
        <tbody>
          ${typeof categories !== 'undefined' && categories.length > 0 ? categories.map(cat => `
            <tr>
              <td><span class="badge badge-info">${cat.slug}</span></td>
              <td style="font-weight: 600; color: var(--text-primary);">${cat.name}</td>
              <td style="color: var(--text-secondary); font-size: 13px;">${cat.description || 'Không có mô tả'}</td>
              <td style="text-align: right;">
                <form action="/admin/categories/${cat.id}/delete" method="POST" style="display: inline;" onsubmit="return confirm('Bạn có chắc chắn muốn xóa danh mục này? Các sản phẩm thuộc danh mục này có thể bị mất phân loại!');">
                  <button type="submit" class="btn btn-danger btn-sm btn-icon">
                    <i class="fas fa-trash"></i>
                  </button>
                </form>
              </td>
            </tr>
          `).join('') : '<tr><td colspan="4" style="text-align: center; color: var(--text-muted); padding: 24px;">Chưa có danh mục nào.</td></tr>'}
        </tbody>
      </table>
    </div>
  </div>

  <!-- Add Category Form -->
  <div class="card">
    <div class="card-title">
      <i class="fas fa-plus text-success"></i> Thêm Danh Mục
    </div>
    <form action="/admin/categories/add" method="POST">
      <div class="form-group">
        <label class="form-label">Tên Danh Mục</label>
        <input type="text" name="name" class="form-input" placeholder="VD: 3D Models" required>
      </div>
      <div class="form-group">
        <label class="form-label">Mô tả (Tùy chọn)</label>
        <textarea name="description" class="form-textarea" rows="4" placeholder="Nhập mô tả ngắn..."></textarea>
      </div>
      <button type="submit" class="btn btn-primary" style="width: 100%; justify-content: center; margin-top: 8px;">
        <i class="fas fa-check"></i> Tạo Danh Mục
      </button>
    </form>
  </div>

</div>
`;
%>
<%- include('./layout', { body: categoriesHtml }) %>
