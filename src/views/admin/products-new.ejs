<%
const newProductHtml = `
<!-- Quill.js CSS -->
<link href="https://cdn.jsdelivr.net/npm/quill@2.0.2/dist/quill.snow.css" rel="stylesheet" />

<style>
  /* Premium Quill editor custom styles */
  .ql-toolbar.ql-snow {
    border: 1px solid var(--border) !important;
    border-top-left-radius: 12px;
    border-top-right-radius: 12px;
    background: rgba(255, 255, 255, 0.03);
  }
  .ql-container.ql-snow {
    border: 1px solid var(--border) !important;
    border-bottom-left-radius: 12px;
    border-bottom-right-radius: 12px;
    background: rgba(10, 11, 16, 0.5);
    color: var(--text-primary);
    font-family: 'Inter', sans-serif;
    font-size: 13.5px;
  }
  .ql-editor {
    min-height: 250px;
  }
  .ql-snow .ql-stroke {
    stroke: var(--text-secondary) !important;
  }
  .ql-snow .ql-fill {
    fill: var(--text-secondary) !important;
  }
  .ql-snow .ql-picker {
    color: var(--text-secondary) !important;
  }
  .ql-snow .ql-picker-options {
    background-color: var(--bg-secondary) !important;
    border-color: var(--border) !important;
  }
</style>

<div class="page-header" style="margin-bottom: 28px;">
  <div style="display:flex;align-items:center;justify-content:space-between; flex-wrap: wrap; gap: 16px;">
    <div style="display: flex; flex-direction: column; gap: 6px;">
      <div class="page-title" style="font-size: 24px; font-weight: 800; letter-spacing: -0.03em; background: linear-gradient(90deg, #ffffff, #94a3b8); -webkit-background-clip: text; -webkit-text-fill-color: transparent; display: flex; align-items: center; gap: 10px;">
        <i class="fas fa-box-open" style="color: var(--accent); font-size: 22px;"></i> Đăng sản phẩm mới
      </div>
      <div class="page-subtitle" style="font-size: 13.5px; color: var(--text-secondary); opacity: 0.85;">Tạo sản phẩm mới, tích hợp các trường dữ liệu tùy biến theo danh mục.</div>
    </div>
    <a href="/admin/products" class="btn btn-ghost" style="display: flex; align-items: center; gap: 8px;">
      <i class="fas fa-arrow-left"></i> Quay lại
    </a>
  </div>
</div>

<form action="/admin/products/new" method="POST" enctype="multipart/form-data" id="new-product-form" class="row g-4"
  x-data="{
    activeZone: 'gallery', // 'thumbnail' or 'gallery'
    thumbnailData: '',
    gallery: [],
    productId: 'prod-' + Date.now().toString().slice(-6) + '-' + Math.floor(Math.random() * 1000),
    newVer: '1.0.0',
    newChangelog: 'Bản phát hành đầu tiên',
    uploadProgress: 0,
    isUploading: false,
    uploadedFileKey: '',
    uploadedFileName: '',
    uploadedFileSize: 0,
    isSavingProduct: false,
    compressAndAdd(file, target) {
      if (!file || !file.type.startsWith('image/')) return;
      const reader = new FileReader();
      reader.onload = (e) => {
        const img = new Image();
        img.onload = () => {
          const canvas = document.createElement('canvas');
          let width = img.width;
          let height = img.height;
          const MAX_WIDTH = 1200;
          const MAX_HEIGHT = 1200;
          if (width > height) {
            if (width > MAX_WIDTH) {
              height *= MAX_WIDTH / width;
              width = MAX_WIDTH;
            }
          } else {
            if (height > MAX_HEIGHT) {
              width *= MAX_HEIGHT / height;
              height = MAX_HEIGHT;
            }
          }
          canvas.width = width;
          canvas.height = height;
          const ctx = canvas.getContext('2d');
          ctx.drawImage(img, 0, 0, width, height);
          
          // Compress to JPEG 0.75 to reduce size to 100-200KB
          const dataUrl = canvas.toDataURL('image/jpeg', 0.75);
          if (target === 'thumbnail') {
            this.thumbnailData = dataUrl;
          } else {
            this.gallery.push({ id: Date.now() + Math.random(), data: dataUrl });
          }
        };
        img.src = e.target.result;
      };
      reader.readAsDataURL(file);
    },
    addFiles(files, target) {
      const dest = target || this.activeZone;
      if (dest === 'thumbnail') {
        const file = files[0];
        this.compressAndAdd(file, 'thumbnail');
      } else {
        for (let i = 0; i < files.length; i++) {
          this.compressAndAdd(files[i], 'gallery');
        }
      }
    },
    removeImage(id) {
      this.gallery = this.gallery.filter(item => item.id !== id);
    },
    async triggerVersionUpload(e) {
      const file = e.target.files[0];
      if (!file) return;
      this.isUploading = true;
      this.uploadProgress = 0;
      try {
        const res = await fetch('/admin/api/presign', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ fileName: file.name, fileType: file.type, productId: this.productId })
        });
        const data = await res.json();
        if (data.error) throw new Error(data.error);
        if (data.isLocal) {
          const formData = new FormData();
          formData.append('file', file);
          const xhr = new XMLHttpRequest();
          xhr.open('POST', data.uploadUrl, true);
          xhr.upload.onprogress = (event) => {
            if (event.lengthComputable) {
              this.uploadProgress = Math.round((event.loaded / event.total) * 100);
            }
          };
          xhr.onload = () => {
            if (xhr.status === 200) {
              const resData = JSON.parse(xhr.responseText);
              this.uploadedFileKey = resData.fileKey;
              this.uploadedFileName = resData.fileName;
              this.uploadedFileSize = resData.fileSize;
              this.isUploading = false;
              this.uploadProgress = 100;
              Notifier.success('Tải tệp tin lên máy chủ thành công!');
            } else {
              this.isUploading = false;
              Notifier.error('Upload cục bộ thất bại: ' + xhr.statusText);
            }
          };
          xhr.onerror = () => {
            this.isUploading = false;
            Notifier.error('Lỗi kết nối khi tải lên server cục bộ');
          };
          xhr.send(formData);
        } else {
          const xhr = new XMLHttpRequest();
          xhr.open('PUT', data.uploadUrl, true);
          xhr.setRequestHeader('Content-Type', file.type);
          xhr.upload.onprogress = (event) => {
            if (event.lengthComputable) {
              this.uploadProgress = Math.round((event.loaded / event.total) * 100);
            }
          };
          xhr.onload = () => {
            if (xhr.status === 200) {
              this.uploadedFileKey = data.fileKey;
              this.uploadedFileName = file.name;
              this.uploadedFileSize = file.size;
              this.isUploading = false;
              this.uploadProgress = 100;
              Notifier.success('Tải tệp tin lên Cloudflare R2 thành công!');
            } else {
              this.isUploading = false;
              Notifier.error('Upload thất bại: ' + xhr.statusText);
            }
          };
          xhr.onerror = () => {
            this.isUploading = false;
            Notifier.error('Lỗi kết nối khi tải lên Cloudflare R2');
          };
          xhr.send(file);
        }
      } catch (err) {
        this.isUploading = false;
        Notifier.error('Lỗi: ' + err.message);
      }
    }
  }"
  @paste.window="
    if (['INPUT', 'TEXTAREA'].includes($event.target.tagName) || $event.target.closest('.ql-editor')) return;
    if ($event.clipboardData && $event.clipboardData.files.length > 0) {
      addFiles($event.clipboardData.files);
    }
  "
>
  <input type="hidden" name="description" id="hidden-description">

  <!-- Left Column: Core Info & Quill Description -->
  <div class="col-lg-8">
    <div class="card" style="background: linear-gradient(135deg, rgba(25,28,48,0.65), rgba(15,17,28,0.7)); display: flex; flex-direction: column; gap: 20px; padding: 28px;">
      <div style="font-size:16px; font-weight:700; color:var(--text-primary); border-bottom: 1px solid var(--border); padding-bottom: 12px; display:flex; align-items:center; gap:8px;">
        <i class="fas fa-file-invoice" style="color: var(--accent);"></i> Thông tin cơ bản
      </div>
      
      <div class="form-group">
        <label class="form-label" style="font-size: 12.5px; font-weight: 600; color: var(--text-primary); margin-bottom: 6px; display: block;">Tên sản phẩm *</label>
        <input type="text" name="title" class="form-input" placeholder="VD: Premium Skyblock Spawn" required style="width:100%;">
