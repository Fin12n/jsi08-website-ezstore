      <div class="form-group">
        <label class="form-label" style="font-size: 12.5px; font-weight: 600; color: var(--text-primary); margin-bottom: 6px; display: block;">Mô tả chi tiết sản phẩm *</label>
        <div id="editor-container"></div>
      </div>
