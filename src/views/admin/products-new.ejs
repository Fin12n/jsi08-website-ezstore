          :style="activeZone === 'thumbnail' ? 'border-color: var(--accent); box-shadow: 0 0 0 3px rgba(99,102,241,0.15);' : 'border-color: rgba(255,255,255,0.08);'"
          style="border: 2px dashed rgba(255,255,255,0.08); border-radius: 10px; padding: 16px; text-align: center; cursor: pointer; transition: all 0.2s; background: rgba(255, 255, 255, 0.012);"
          onmouseover="this.style.background='rgba(255, 255, 255, 0.025)'"
          onmouseout="this.style.background='rgba(255, 255, 255, 0.012)'"
        >
          <template x-if="!thumbnailData">
            <div>
              <i class="fa-solid fa-image" style="font-size: 18px; color: var(--text-muted); margin-bottom: 4px;"></i>
