              onmouseover="this.style.background='rgba(244,63,94,1)'"
              onmouseout="this.style.background='rgba(244,63,94,0.85)'"
            >
              <i class="fa-solid fa-xmark" style="font-size: 9px;"></i>
            </button>
            <input type="hidden" name="galleryBase64[]" :value="img.data">
          </div>
        </template>
      </div>
    </div>

    <!-- Category Dynamic Fields -->
    <div class="card" id="dynamic-fields-wrapper" style="background: linear-gradient(135deg, rgba(25,28,48,0.65), rgba(15,17,28,0.7)); padding: 24px; display: none;">
      <div style="font-size:15px; font-weight:700; color:var(--text-primary); margin-bottom:16px; display:flex; align-items:center; gap:8px;">
        <i class="fas fa-sliders" style="color: var(--warning);"></i> Thông số danh mục
      </div>
      <div id="dynamic-fields-container" style="display:flex; flex-direction:column; gap:14px;">
        <!-- Inputs dynamically injected here -->
      </div>
    </div>

    <!-- Lists inputs (Tags) -->
    <div class="card" style="background: linear-gradient(135deg, rgba(25,28,48,0.65), rgba(15,17,28,0.7)); padding: 24px; display: flex; flex-direction: column; gap: 14px;">
