                Dung lượng: <span x-text="Math.round(uploadedFileSize / 1024) + ' KB'"></span>
              </div>
            </div>
            <button type="button" @click="uploadedFileKey=''; uploadedFileName=''; uploadedFileSize=0;" class="btn btn-sm btn-ghost" style="color:var(--danger); border:1px solid rgba(244,63,94,0.2); padding:6px 10px; display:flex; align-items:center; justify-content:center;" title="Xóa tệp">
              <i class="fa-solid fa-trash-can"></i>
            </button>
          </div>
        </div>
        
        <input type="file" x-ref="versionFileInput" @change="triggerVersionUpload($event)" style="display:none;">
      </div>

      <!-- Hidden inputs for version metadata link -->
      <input type="hidden" name="productId" :value="productId">
      <input type="hidden" name="versionFileKey" :value="uploadedFileKey">
      <input type="hidden" name="versionFileName" :value="uploadedFileName">
      <input type="hidden" name="versionFileSize" :value="uploadedFileSize">
    </div>

    <!-- Submit Panel -->
    <div class="card" style="background: linear-gradient(135deg, rgba(25,28,48,0.65), rgba(15,17,28,0.7)); padding: 20px;">
      <button type="submit" class="btn btn-primary" style="width:100%; display:flex; align-items:center; justify-content:center; gap:8px; font-size:14px; font-weight:700;">
        <i class="fas fa-cloud-arrow-up"></i> Đăng sản phẩm
      </button>
    </div>
  </div>
</form>
`;

const extraScript = `
<!-- Quill.js JS -->
<script src="https://cdn.jsdelivr.net/npm/quill@2.0.2/dist/quill.js"></script>
<script>
  const categories = ${typeof categories !== 'undefined' ? JSON.stringify(categories) : '[]'};

  function initProductsNew() {
    // 1. Initialize Quill Editor
    const quill = new Quill('#editor-container', {
      theme: 'snow',
      modules: {
        toolbar: [
          [{ 'header': [1, 2, 3, false] }],
          ['bold', 'italic', 'underline', 'strike'],
          [{ 'list': 'ordered'}, { 'list': 'bullet' }],
          ['link', 'clean']
        ]
      }
    });

    // 2. Handle Category Dynamic Fields
    const selectEl = document.getElementById('category-select');
    const wrapper = document.getElementById('dynamic-fields-wrapper');
    const container = document.getElementById('dynamic-fields-container');
    if (!selectEl) return;

    selectEl.addEventListener('change', function() {
      const slug = this.value;
      const cat = categories.find(c => c.slug === slug);
      
      container.innerHTML = '';
      if (cat && cat.fields && cat.fields.length > 0) {
        wrapper.style.display = 'block';
        cat.fields.forEach(f => {
          let inputHtml = '';
          const reqAttr = f.required ? 'required' : '';
          const reqStar = f.required ? '<span style="color:var(--danger)">*</span>' : '';
          
          if (f.type === 'select') {
            const optionsHtml = (f.options || []).map(opt => '<option value="' + opt + '">' + opt + '</option>').join('');
            inputHtml = '<div class="form-group">' +
              '<label class="form-label" style="font-size: 12.5px; font-weight: 600; color: var(--text-primary); margin-bottom: 6px; display: block;">' + f.name + ' ' + reqStar + '</label>' +
              '<select name="customFields[' + f.name + ']" class="form-select" style="width:100%;" ' + reqAttr + '>' +
                '<option value="">-- Chọn --</option>' +
                optionsHtml +
              '</select>' +
            '</div>';
          } else if (f.type === 'number') {
            inputHtml = '<div class="form-group">' +
              '<label class="form-label" style="font-size: 12.5px; font-weight: 600; color: var(--text-primary); margin-bottom: 6px; display: block;">' + f.name + ' ' + reqStar + '</label>' +
              '<input type="number" name="customFields[' + f.name + ']" class="form-input" placeholder="Nhập số..." style="width:100%;" ' + reqAttr + '>' +
            '</div>';
          } else {
            inputHtml = '<div class="form-group">' +
              '<label class="form-label" style="font-size: 12.5px; font-weight: 600; color: var(--text-primary); margin-bottom: 6px; display: block;">' + f.name + ' ' + reqStar + '</label>' +
              '<input type="text" name="customFields[' + f.name + ']" class="form-input" placeholder="Nhập chữ..." style="width:100%;" ' + reqAttr + '>' +
            '</div>';
          }
          container.insertAdjacentHTML('beforeend', inputHtml);
        });
      } else {
        wrapper.style.display = 'none';
      }
    });

    // 3. Sync Quill content to hidden field before form submission
    const form = document.getElementById('new-product-form');
    form.addEventListener('submit', function(e) {
      const descHtml = quill.getSemanticHTML(); // gets semantic HTML content
      document.getElementById('hidden-description').value = descHtml;
    });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initProductsNew);
  } else {
    initProductsNew();
  }
</script>
`;
%>
<%- include('./layout', { body: newProductHtml, extraScript }) %>
