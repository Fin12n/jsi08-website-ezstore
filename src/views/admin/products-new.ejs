      <div class="form-group">
        <label class="form-label" style="font-size: 11.5px; font-weight: 600; color: var(--text-secondary); margin-bottom: 4px; display: block;">Quà tặng & Bảo hành (Gifts)</label>
        <input type="text" name="gifts" class="form-input" placeholder="VD: Tặng kèm 1 setup phụ" style="width:100%;">
      </div>
    </div>

    <!-- Initial Product File Version (Optional) -->
    <div class="card" style="background: linear-gradient(135deg, rgba(25,28,48,0.65), rgba(15,17,28,0.7)); padding: 24px; display: flex; flex-direction: column; gap: 14px;">
      <div style="font-size:15px; font-weight:700; color:var(--text-primary); display:flex; align-items:center; gap:8px;">
        <i class="fas fa-file-zipper" style="color: var(--accent-light);"></i> Tệp tài nguyên (Phiên bản đầu tiên)
      </div>
      
      <div style="display:grid; grid-template-columns:1fr 2fr; gap:10px;">
        <div class="form-group">
          <label class="form-label" style="font-size:11.5px; color:var(--text-secondary); margin-bottom:4px; display:block;">Phiên bản</label>
          <input type="text" x-model="newVer" name="versionNumber" class="form-input" style="width:100%;">
        </div>
        <div class="form-group">
          <label class="form-label" style="font-size:11.5px; color:var(--text-secondary); margin-bottom:4px; display:block;">Mô tả thay đổi</label>
          <input type="text" x-model="newChangelog" name="versionChangelog" class="form-input" style="width:100%;">
        </div>
      </div>

      <div class="form-group">
        <label class="form-label" style="font-size:11.5px; color:var(--text-secondary); margin-bottom:4px; display:block;">Chọn tệp tin tài nguyên</label>
        
        <!-- Upload Trigger or Status -->
        <div style="border:1px solid rgba(255,255,255,0.08); border-radius:10px; padding:12px; background:rgba(0,0,0,0.2);">
          <!-- When not uploading and no file uploaded -->
          <div x-show="!isUploading && !uploadedFileKey" style="display:flex; align-items:center; justify-content:space-between; gap:10px;">
            <span style="font-size:12px; color:var(--text-secondary);">Chưa có tệp nào được chọn</span>
            <button type="button" @click="$refs.versionFileInput.click()" class="btn btn-sm btn-ghost" style="padding: 6px 12px; font-size:11.5px; display:flex; align-items:center; gap:4px; border:1px solid var(--border);">
              <i class="fa-solid fa-file-import"></i> Chọn tệp
            </button>
          </div>

          <!-- When uploading -->
          <div x-show="isUploading" style="display:flex; flex-direction:column; gap:8px;">
            <div style="display:flex; align-items:center; justify-content:space-between;">
              <span style="font-size:12px; color:var(--text-secondary); display:flex; align-items:center; gap:6px;">
                <i class="fa-solid fa-spinner fa-spin" style="color:var(--accent-light);"></i> Đang tải lên...
              </span>
              <span x-text="uploadProgress + '%'" style="font-size:12px; font-weight:700; color:var(--accent-light);"></span>
            </div>
            <div style="width:100%; height:6px; background:rgba(255,255,255,0.05); border-radius:3px; overflow:hidden;">
              <div :style="'width: ' + uploadProgress + '%'" style="height:100%; background:var(--accent); transition:width 0.2s ease;"></div>
            </div>
          </div>

          <!-- When uploaded successfully -->
