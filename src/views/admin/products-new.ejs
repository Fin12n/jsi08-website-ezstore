      >
        <i class="fa-solid fa-cloud-arrow-up" style="font-size: 24px; color: var(--text-muted); margin-bottom: 8px;"></i>
        <span style="font-size: 12.5px; color: var(--text-secondary); display: block; font-weight: 500;">
