<%
  const userList = typeof usersList !== 'undefined' ? usersList : [];
  const filterSearch = typeof filters !== 'undefined' && filters.search ? filters.search : '';
  const filterRole = typeof filters !== 'undefined' && filters.role ? filters.role : '';
  const filterStatus = typeof filters !== 'undefined' && filters.status ? filters.status : '';

  let rowsHtml = '';
  if (userList.length > 0) {
    userList.forEach(function(u) {
      const initial = (u.displayName || u.email || 'U').charAt(0).toUpperCase();
      const isDeleted = !!u.deletedAt;
      const isBanned = u.bannedAt && !u.unbannedAt;
      const uid = u.id || '';
      const uName = u.displayName || u.email || uid;

      // Role badge — new Pro Max style
      const roleBadge = u.role === 'admin'
        ? '<span class="badge badge-danger">Admin</span>'
        : u.role === 'seller'
          ? '<span class="badge badge-info">Seller</span>'
          : '<span class="badge badge-muted">User</span>';

      // Status badge — new dot-indicator style
      const statusBadge = isBanned
        ? '<span class="badge badge-warning"><i class="fas fa-ban" style="font-size:9px;margin-right:2px;"></i> Bị cấm</span>'
        : '<span class="badge badge-success">Hoạt động</span>';

      // Wallet balance color
      const balance = (u.walletBalance || 0).toLocaleString('vi-VN');

      // Build action dropdown with new classes
      let actionItems = '';
      actionItems  = '<button class="action-dropdown-item" onclick="openWalletModal(\'' + uid + '\', \'' + uName.replace(/'/g, "\\'") + '\')"><i class="fas fa-wallet" style="color:var(--accent-light);"></i> Điều chỉnh ví</button>';
      actionItems += '<button class="action-dropdown-item" onclick="confirmOtp(\'Force Logout\',\'Hủy phiên đăng nhập của ' + uName + '?\',\'/admin/api/users/' + uid + '/force-logout\',{})"><i class="fas fa-right-from-bracket"></i> Force Logout</button>';
      if (isBanned) {
        actionItems += '<button class="action-dropdown-item success" onclick="confirmOtp(\'Mở khóa tài khoản\',\'Mở khóa tài khoản ' + uName + '?\',\'/admin/api/users/' + uid + '/unban\',{})"><i class="fas fa-unlock"></i> Mở khóa</button>';
      } else {
        actionItems += '<button class="action-dropdown-item warning" onclick="confirmOtp(\'Cấm tài khoản\',\'Cấm tài khoản ' + uName + '? Hành động này cần ghi rõ lý do.\',\'/admin/api/users/' + uid + '/ban\',{})"><i class="fas fa-ban"></i> Cấm tài khoản</button>';
      }
      actionItems += '<div class="action-dropdown-divider"></div>';
      actionItems += '<button class="action-dropdown-item danger" onclick="confirmOtp(\'Xóa tài khoản\',\'Xóa tài khoản ' + uName + '? Hành động này sẽ XÓA VĨNH VIỄN tài khoản khỏi hệ thống và không thể khôi phục.\',\'/admin/api/users/' + uid + '/delete\',{})"><i class="fas fa-trash-can"></i> Xóa tài khoản</button>';

      rowsHtml += '<tr>' +
        '<td><div style="display:flex;align-items:center;gap:13px;">' +
          '<div style="width:38px;height:38px;border-radius:50%;background:linear-gradient(135deg,var(--accent),#4f46e5);display:flex;align-items:center;justify-content:center;font-size:14px;font-weight:700;color:white;flex-shrink:0;box-shadow:0 4px 12px rgba(99,102,241,0.4);">' + initial + '</div>' +
          '<div>' +
            '<div style="font-weight:600;color:var(--text-primary);font-size:13.5px;letter-spacing:-0.01em;">' + (u.displayName || u.email || u.id) + '</div>' +
            '<div style="font-size:11.5px;color:var(--text-muted);margin-top:2px;">' + (u.email || u.id) + '</div>' +
          '</div>' +
        '</div></td>' +
        '<td><span style="font-weight:700;color:#34d399;font-size:13px;letter-spacing:-0.01em;">' + balance + ' <span style="font-size:11px;color:var(--text-muted);font-weight:500;">zCoin</span></span></td>' +
        '<td>' + roleBadge + '</td>' +
        '<td>' + statusBadge + '</td>' +
        '<td style="font-size:12.5px;color:var(--text-muted);">' + (u.createdAt ? new Date(u.createdAt).toLocaleDateString('vi-VN') : '--') + '</td>' +
        '<td style="text-align:center;">' +
          '<div x-data="{ open: false }" class="action-dropdown-container">' +
            '<button @click="open = !open" class="action-btn"><i class="fas fa-ellipsis"></i></button>' +
            '<div x-show="open" @click.away="open = false" x-transition class="action-dropdown">' +
              actionItems +
            '</div>' +
          '</div>' +
        '</td>' +
      '</tr>';
    });
  } else {
    rowsHtml = '<tr><td colspan="6" style="text-align:center;padding:48px 24px;"><div style="color:var(--text-muted);font-size:14px;">Không tìm thấy thành viên nào.</div></td></tr>';
  }

  const fullHtml = `
<div class="page-header" style="margin-bottom: 28px; display: flex; flex-direction: column; gap: 6px;">
  <div class="page-title" style="font-size: 24px; font-weight: 800; letter-spacing: -0.03em; background: linear-gradient(90deg, #ffffff, #94a3b8); -webkit-background-clip: text; -webkit-text-fill-color: transparent; display: flex; align-items: center; gap: 10px;">
    <i class="fas fa-user-group" style="color: var(--accent); font-size: 22px;"></i> Quản lý Thành viên
  </div>
  <div class="page-subtitle" style="font-size: 13.5px; color: var(--text-secondary); opacity: 0.85;">Tìm kiếm, phân quyền và quản lý tài chính toàn bộ thành viên trên nền tảng.</div>
</div>

<!-- Filter Bar -->
<form method="GET" action="/admin/users" class="filter-bar" id="users-filter-form" style="margin-bottom: 24px;">
  <div class="filter-search">
    <i class="fas fa-magnifying-glass"></i>
    <input type="text" name="search" class="form-input" placeholder="Tìm theo email, tên, ID..." value="${filterSearch}">
  </div>
  <select name="role" class="form-select" style="width:160px;">
    <option value="">Tất cả vai trò</option>
    <option value="user" ${filterRole === 'user' ? 'selected' : ''}>User</option>
    <option value="seller" ${filterRole === 'seller' ? 'selected' : ''}>Seller</option>
    <option value="admin" ${filterRole === 'admin' ? 'selected' : ''}>Admin</option>
  </select>
  <select name="status" class="form-select" style="width:160px;">
    <option value="">Tất cả trạng thái</option>
    <option value="active" ${filterStatus === 'active' ? 'selected' : ''}>Đang hoạt động</option>
    <option value="banned" ${filterStatus === 'banned' ? 'selected' : ''}>Đã cấm</option>
  </select>
  <button type="submit" class="btn btn-primary" style="display: flex; align-items: center; gap: 8px;"><i class="fas fa-search"></i> Tìm kiếm</button>
  <a href="/admin/users" class="btn btn-ghost" style="display: flex; align-items: center; gap: 8px;"><i class="fas fa-rotate-right"></i> Reset</a>
  <span style="margin-left:auto; font-size:13px; font-weight:600; color:var(--text-secondary); background:var(--bg-card); padding: 8px 14px; border-radius: 8px; border: 1px solid var(--border);">${userList.length} kết quả</span>
</form>

<!-- Users Table -->
<div class="card" style="background: linear-gradient(135deg, rgba(25,28,48,0.65), rgba(15,17,28,0.7));">
  <div class="table-wrap">
    <table class="admin-table">
      <thead>
        <tr>
          <th>Thành viên</th>
          <th>Số dư Ví</th>
          <th>Vai trò</th>
          <th>Trạng thái</th>
          <th>Ngày đăng ký</th>
          <th style="width: 80px; text-align: center;">Thao tác</th>
        </tr>
      </thead>
      <tbody>` + rowsHtml + `
      </tbody>
    </table>
  </div>
</div>

<!-- Wallet Adjust Modal -->
<div id="wallet-modal" style="display:none;position:fixed;inset:0;background:rgba(0,0,0,0.7);z-index:1000;align-items:center;justify-content:center;">
</div>
`;

const extraScript = `<script>
function confirmOtp(title, desc, action, targetData) {
  window.dispatchEvent(new CustomEvent('open-otp-modal', { detail: { title, desc, action, targetData } }));
}
function openWalletModal(userId, userName) {
  var amount = prompt('Điều chỉnh ví cho ' + userName + '\\nNhập số tiền (số dương = cộng, số âm = trừ):');
  if (!amount) return;
  var parsedAmount = parseInt(amount);
  var adjustType = parsedAmount >= 0 ? 'credit' : 'debit';
  var reason = prompt('Nhập lý do:');
  if (!reason) return;
  window.dispatchEvent(new CustomEvent('open-otp-modal', { detail: {
    title: 'Xác nhận điều chỉnh ví',
    desc: (adjustType === 'credit' ? 'Cộng' : 'Trừ') + ' ' + Math.abs(parsedAmount).toLocaleString('vi-VN') + ' zCoin cho ' + userName,
    action: '/admin/api/users/' + userId + '/wallet',
    targetData: { adjustType: adjustType, amount: Math.abs(parsedAmount), reason: reason }
  }}));
}
window.addEventListener('open-otp-modal', function(e) {
  if (window.Alpine) {
    Alpine.$data(document.body).openOtpModal(e.detail);
  }
});
<\/script>`;
%>
<%- include('./layout', { body: fullHtml, extraScript }) %>
