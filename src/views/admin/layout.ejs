<!DOCTYPE html>
<html lang="vi" class="dark">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= typeof title !== 'undefined' ? title : 'Admin - EZ Studio' %></title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
  <script defer src="https://cdn.jsdelivr.net/npm/alpinejs@3.x.x/dist/cdn.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
  <style>
    /* ===== DESIGN TOKENS (PRO MAX AESTHETIC - SPACE DARK) ===== */
    :root {
      --bg-primary: #0a0b10;
      --bg-secondary: #0f1016;
      --bg-card: rgba(20, 22, 32, 0.5);
      --bg-hover: rgba(99, 102, 241, 0.08);
      --border: rgba(255, 255, 255, 0.06);
      --border-accent: rgba(99, 102, 241, 0.25);
      --text-primary: #f1f5f9;
      --text-secondary: #94a3b8;
      --text-muted: #475569;
      --accent: #6366f1;
      --accent-light: #818cf8;
      --accent-glow: rgba(99, 102, 241, 0.15);
      --success: #10b981;
      --success-glow: rgba(16, 185, 129, 0.15);
      --warning: #f59e0b;
      --warning-glow: rgba(245, 158, 11, 0.15);
      --danger: #f43f5e;
      --danger-glow: rgba(244, 63, 94, 0.15);
      
      --sidebar-width: 280px;
      --header-height: 70px;
      --radius: 16px;
      --radius-sm: 10px;
      --radius-md: 14px;
      --shadow: 0 10px 40px -10px rgba(0, 0, 0, 0.7);
      --shadow-sm: 0 4px 20px rgba(0, 0, 0, 0.4);
      --transition: 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    }

    /* ===== RESET & BASE ===== */
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    [x-cloak] { display: none !important; }
    html { scroll-behavior: smooth; }
    body { font-family: 'Inter', sans-serif; background: var(--bg-primary); color: var(--text-primary); min-height: 100vh; display: flex; overflow: hidden; -webkit-font-smoothing: antialiased; }

    /* ===== SCROLLBAR ===== */
    ::-webkit-scrollbar { width: 5px; height: 5px; }
    ::-webkit-scrollbar-track { background: transparent; }
    ::-webkit-scrollbar-thumb { background: rgba(255, 255, 255, 0.08); border-radius: 10px; }
    ::-webkit-scrollbar-thumb:hover { background: rgba(255, 255, 255, 0.15); }

    /* ===== SIDEBAR ===== */
    .admin-sidebar {
      width: var(--sidebar-width); min-width: var(--sidebar-width);
      height: 100vh; background: var(--bg-secondary);
      border-right: 1px solid var(--border);
      display: flex; flex-direction: column;
      position: fixed; left: 0; top: 0; z-index: 100;
      transition: transform var(--transition);
    }
    .sidebar-logo {
      padding: 24px;
      border-bottom: 1px solid var(--border);
      display: flex; align-items: center; gap: 12px;
    }
    .sidebar-logo .logo-icon {
      width: 36px; height: 36px; border-radius: 10px;
      background: linear-gradient(135deg, var(--accent), #4f46e5);
      box-shadow: 0 4px 14px var(--accent-glow);
      display: flex; align-items: center; justify-content: center;
      font-size: 16px; font-weight: 800; color: white;
    }
    .sidebar-logo .logo-text { font-size: 15px; font-weight: 700; color: var(--text-primary); letter-spacing: -0.02em; }
    .sidebar-logo .logo-badge { font-size: 9px; color: var(--accent-light); font-weight: 700; letter-spacing: 0.05em; background: var(--accent-glow); padding: 2px 6px; border-radius: 4px; margin-left: auto; }

    .sidebar-nav { flex: 1; overflow-y: auto; padding: 16px 0; }
    .nav-section { padding: 12px 24px 6px; }
    .nav-section-label { font-size: 10px; font-weight: 700; color: var(--text-muted); letter-spacing: 0.12em; text-transform: uppercase; }

    .nav-item { margin: 2px 14px; border-radius: var(--radius-sm); overflow: hidden; }
    .nav-link {
      display: flex; align-items: center; gap: 12px;
      padding: 10px 14px; color: var(--text-secondary);
      text-decoration: none; font-size: 13.5px; font-weight: 500;
      transition: all var(--transition); border-radius: var(--radius-sm);
      position: relative;
    }
    .nav-link:hover { background: var(--bg-hover); color: var(--text-primary); }
    .nav-link.active { background: rgba(99, 102, 241, 0.1); color: var(--text-primary); font-weight: 600; border: 1px solid rgba(99, 102, 241, 0.15); }
    .nav-link.active::before { content: ''; position: absolute; left: 0; top: 25%; bottom: 25%; width: 3px; background: var(--accent); border-radius: 0 4px 4px 0; }
    .nav-link i { width: 18px; text-align: center; font-size: 14px; color: var(--text-secondary); opacity: 0.7; transition: color var(--transition); }
    .nav-link:hover i, .nav-link.active i { color: var(--accent-light); opacity: 1; }
    
    .nav-badge {
      margin-left: auto; min-width: 18px; height: 18px; padding: 0 5px;
      background: var(--danger); color: white; font-size: 10px; font-weight: 700;
      border-radius: 10px; display: flex; align-items: center; justify-content: center;
      box-shadow: 0 2px 8px var(--danger-glow);
    }
    .nav-badge.warning { background: var(--warning); color: #fff; box-shadow: 0 2px 8px var(--warning-glow); }

    .sidebar-footer {
      padding: 18px 24px; border-top: 1px solid var(--border);
      display: flex; align-items: center; gap: 12px;
      background: rgba(0, 0, 0, 0.1);
    }
    .admin-avatar {
      width: 36px; height: 36px; border-radius: 50%;
      background: linear-gradient(135deg, var(--accent), #4f46e5);
      display: flex; align-items: center; justify-content: center;
      font-size: 13px; font-weight: 700; color: white; flex-shrink: 0;
      border: 1px solid rgba(255, 255, 255, 0.1);
      box-shadow: 0 4px 10px rgba(0, 0, 0, 0.2);
    }
    .admin-info { flex: 1; min-width: 0; }
    .admin-name { font-size: 13px; font-weight: 600; color: var(--text-primary); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
    .admin-role { font-size: 11px; color: var(--text-secondary); opacity: 0.8; }

    /* ===== MAIN LAYOUT ===== */
    .admin-main { margin-left: var(--sidebar-width); flex: 1; height: 100vh; display: flex; flex-direction: column; overflow: hidden; background: radial-gradient(circle at top right, rgba(99, 102, 241, 0.05), transparent 45%), var(--bg-primary); }

    /* ===== TOPBAR ===== */
    .admin-topbar {
      height: var(--header-height); min-height: var(--header-height);
      background: rgba(10, 11, 16, 0.7); backdrop-filter: blur(16px); border-bottom: 1px solid var(--border);
      display: flex; align-items: center; padding: 0 40px; gap: 20px;
      position: sticky; top: 0; z-index: 50;
    }
    .topbar-search-btn {
      flex: 1; max-width: 380px;
      display: flex; align-items: center; gap: 12px;
      background: rgba(0, 0, 0, 0.2); border: 1px solid var(--border);
      border-radius: var(--radius-sm); padding: 9px 16px;
      cursor: pointer; transition: all var(--transition); color: var(--text-secondary); font-size: 13px;
    }
    .topbar-search-btn:hover { border-color: var(--border-accent); background: rgba(255, 255, 255, 0.02); color: var(--text-primary); box-shadow: 0 0 0 3px var(--accent-glow); }
    .topbar-search-btn .kbd {
      margin-left: auto; font-size: 10px; font-weight: 600; background: var(--bg-primary);
      padding: 3px 6px; border-radius: 4px; border: 1px solid var(--border); color: var(--text-secondary);
    }
    .topbar-right { display: flex; align-items: center; gap: 16px; margin-left: auto; }
    .topbar-icon-btn {
      width: 38px; height: 38px; border-radius: var(--radius-sm);
      background: transparent; border: 1px solid transparent;
      color: var(--text-secondary); cursor: pointer;
      display: flex; align-items: center; justify-content: center;
      transition: all var(--transition); font-size: 15px; position: relative;
    }
    .topbar-icon-btn:hover { background: var(--bg-hover); color: var(--text-primary); border-color: var(--border); }
    .notification-dot { position: absolute; top: 6px; right: 6px; width: 6px; height: 6px; background: var(--danger); border-radius: 50%; border: 1.5px solid var(--bg-primary); }

    /* ===== CONTENT AREA ===== */
    .admin-content { flex: 1; overflow-y: auto; padding: 36px 40px; }
    .page-header { margin-bottom: 32px; }
    .page-title { font-size: 24px; font-weight: 700; color: var(--text-primary); letter-spacing: -0.02em; }
    .page-subtitle { font-size: 13px; color: var(--text-secondary); margin-top: 6px; opacity: 0.9; }

    /* ===== CARDS ===== */
    .card {
      background: var(--bg-card); border: 1px solid var(--border); backdrop-filter: blur(20px);
      border-radius: var(--radius); padding: 24px; box-shadow: var(--shadow-sm);
      position: relative; overflow: hidden;
    }
    .card::before { content: ''; position: absolute; top: 0; left: 0; right: 0; height: 1px; background: linear-gradient(90deg, transparent, rgba(255,255,255,0.06), transparent); }
    .card-title { font-size: 13px; font-weight: 700; color: var(--text-primary); text-transform: uppercase; letter-spacing: 0.08em; margin-bottom: 20px; display: flex; align-items: center; gap: 8px; opacity: 0.95; }

    /* ===== FILTER BAR ===== */
    .filter-bar {
      display: flex; flex-wrap: wrap; align-items: center; gap: 12px;
      background: var(--bg-card); border: 1px solid var(--border); backdrop-filter: blur(20px);
      padding: 14px 20px; border-radius: var(--radius-md); margin-bottom: 24px;
      box-shadow: var(--shadow-sm);
    }
    .filter-search { position: relative; flex: 1; min-width: 220px; }
    .filter-search i { position: absolute; left: 14px; top: 50%; transform: translateY(-50%); color: var(--text-secondary); opacity: 0.7; font-size: 13px; }
    .filter-search .form-input { padding-left: 38px; }

    /* ===== STATS CARDS ===== */
    .stats-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: 20px; margin-bottom: 32px; }
    .stat-card {
      background: linear-gradient(180deg, var(--bg-card) 0%, rgba(15,16,22,0.4) 100%);
      border: 1px solid var(--border); backdrop-filter: blur(20px);
      border-radius: var(--radius); padding: 22px;
      display: flex; align-items: center; gap: 16px;
      transition: all var(--transition); position: relative; overflow: hidden;
      box-shadow: var(--shadow-sm);
    }
    .stat-card::before { content: ''; position: absolute; top: 0; left: 0; width: 100%; height: 1px; background: linear-gradient(90deg, transparent, rgba(255,255,255,0.08), transparent); }
    .stat-card:hover { border-color: var(--border-accent); transform: translateY(-3px); box-shadow: 0 12px 30px rgba(0,0,0,0.5); }
    .stat-icon {
      width: 48px; height: 48px; border-radius: 12px;
      display: flex; align-items: center; justify-content: center;
      font-size: 20px; flex-shrink: 0; box-shadow: inset 0 2px 4px rgba(255,255,255,0.05);
    }
    .stat-icon.green { background: linear-gradient(135deg, rgba(16,185,129,0.15), rgba(16,185,129,0.03)); color: var(--success); border: 1px solid rgba(16,185,129,0.15); }
    .stat-icon.blue { background: linear-gradient(135deg, rgba(99,102,241,0.15), rgba(99,102,241,0.03)); color: var(--accent-light); border: 1px solid rgba(99,102,241,0.15); }
    .stat-icon.yellow { background: linear-gradient(135deg, rgba(245,158,11,0.15), rgba(245,158,11,0.03)); color: var(--warning); border: 1px solid rgba(245,158,11,0.15); }
    .stat-icon.red { background: linear-gradient(135deg, rgba(244,63,94,0.15), rgba(244,63,94,0.03)); color: var(--danger); border: 1px solid rgba(244,63,94,0.15); }
    .stat-value { font-size: 24px; font-weight: 700; color: var(--text-primary); line-height: 1.1; letter-spacing: -0.02em; }
    .stat-label { font-size: 12px; font-weight: 500; color: var(--text-secondary); margin-top: 5px; opacity: 0.85; }

    /* ===== TABLES ===== */
    .table-wrap { overflow: visible; border-radius: var(--radius); border: 1px solid var(--border); background: transparent; }
    @media (max-width: 991px) {
      .table-wrap { overflow-x: auto; }
    }
    table { width: 100%; border-collapse: collapse; font-size: 13.5px; }
    thead tr { background: rgba(255,255,255,0.015); }
    thead th { padding: 13px 18px; text-align: left; font-size: 10.5px; font-weight: 700; color: var(--text-muted); text-transform: uppercase; letter-spacing: 0.1em; border-bottom: 1px solid var(--border); white-space: nowrap; }
    tbody td { padding: 0; border-bottom: 1px solid rgba(255,255,255,0.025); color: var(--text-primary); vertical-align: middle; transition: background var(--transition); }
    tbody td > * { padding: 15px 18px; display: block; }
    tbody td:first-child > * { border-radius: var(--radius-sm) 0 0 var(--radius-sm); }
    tbody td:last-child > * { border-radius: 0 var(--radius-sm) var(--radius-sm) 0; }
    tbody tr:hover td { background: rgba(99,102,241,0.04); }
    tbody tr:hover td:first-child > * { background: transparent; }
    tbody tr:last-child td { border-bottom: none; }
    /* Simpler td styles — avoid forcing display:block on everything */
    .admin-table tbody td { padding: 14px 18px; }
    .admin-table tbody tr { transition: background var(--transition); }
    .admin-table tbody tr:hover { background: rgba(99,102,241,0.035); }
    .admin-table thead th { padding: 13px 18px; font-size: 10.5px; font-weight: 700; color: var(--text-muted); text-transform: uppercase; letter-spacing: 0.1em; border-bottom: 1px solid var(--border); background: rgba(0,0,0,0.15); }

    /* ===== BADGES — PRO MAX ===== */
    .badge {
      display: inline-flex; align-items: center; gap: 6px;
      padding: 4px 11px 4px 9px; border-radius: 8px;
      font-size: 11.5px; font-weight: 600; white-space: nowrap;
      border: 1px solid transparent; letter-spacing: 0.01em;
    }
    .badge::before {
      content: ''; width: 6px; height: 6px; border-radius: 50%; flex-shrink: 0;
    }
    .badge-success { background: rgba(16,185,129,0.1); color: #34d399; border-color: rgba(16,185,129,0.2); }
    .badge-success::before { background: #10b981; box-shadow: 0 0 6px rgba(16,185,129,0.7); }
    .badge-warning { background: rgba(245,158,11,0.1); color: #fbbf24; border-color: rgba(245,158,11,0.2); }
    .badge-warning::before { background: #f59e0b; box-shadow: 0 0 6px rgba(245,158,11,0.7); }
    .badge-danger { background: rgba(244,63,94,0.1); color: #fb7185; border-color: rgba(244,63,94,0.2); }
    .badge-danger::before { background: #f43f5e; box-shadow: 0 0 6px rgba(244,63,94,0.7); }
    .badge-info { background: rgba(99,102,241,0.1); color: #a5b4fc; border-color: rgba(99,102,241,0.2); }
    .badge-info::before { background: #6366f1; box-shadow: 0 0 6px rgba(99,102,241,0.7); }
    .badge-muted { background: rgba(255,255,255,0.04); color: var(--text-secondary); border-color: rgba(255,255,255,0.07); }
    .badge-muted::before { background: rgba(255,255,255,0.3); }

    /* ===== BUTTONS — PRO MAX ===== */
    .btn { display: inline-flex; align-items: center; justify-content: center; gap: 8px; padding: 9px 20px; border-radius: var(--radius-sm); font-size: 13px; font-weight: 600; cursor: pointer; border: 1px solid transparent; transition: all var(--transition); text-decoration: none; white-space: nowrap; user-select: none; }
    .btn-primary { background: linear-gradient(135deg, #6366f1, #4f46e5); color: white; box-shadow: 0 1px 0 rgba(255,255,255,0.12) inset, 0 2px 8px rgba(99,102,241,0.35); border-color: rgba(99,102,241,0.4); }
    .btn-primary:hover { transform: translateY(-1.5px); box-shadow: 0 1px 0 rgba(255,255,255,0.15) inset, 0 6px 20px rgba(99,102,241,0.5); filter: brightness(1.08); }
    .btn-primary:active { transform: translateY(0); filter: brightness(0.94); box-shadow: 0 1px 4px rgba(99,102,241,0.2); }

    .btn-danger { background: rgba(244,63,94,0.07); color: #fb7185; border-color: rgba(244,63,94,0.18); }
    .btn-danger:hover { background: rgba(244,63,94,0.12); border-color: rgba(244,63,94,0.3); transform: translateY(-1px); }

    .btn-success { background: rgba(16,185,129,0.07); color: #34d399; border-color: rgba(16,185,129,0.18); }
    .btn-success:hover { background: rgba(16,185,129,0.12); border-color: rgba(16,185,129,0.3); }

    .btn-ghost { background: rgba(255,255,255,0.03); color: var(--text-secondary); border-color: var(--border); }
    .btn-ghost:hover { background: rgba(255,255,255,0.06); color: var(--text-primary); border-color: rgba(255,255,255,0.12); }

    .btn-sm { padding: 5px 12px; font-size: 12px; border-radius: 8px; }
    .btn-icon { width: 34px; height: 34px; padding: 0; border-radius: 8px; }
    /* Ellipsis action button */
    .action-btn { width: 30px; height: 30px; border-radius: 8px; background: rgba(255,255,255,0.04); border: 1px solid var(--border); color: var(--text-secondary); cursor: pointer; display: inline-flex; align-items: center; justify-content: center; font-size: 14px; transition: all var(--transition); }
    .action-btn:hover { background: rgba(99,102,241,0.1); border-color: rgba(99,102,241,0.3); color: var(--accent-light); }
    /* Dropdown menu */
    .action-dropdown { position: absolute; right: 0; top: calc(100% + 6px); z-index: 1000; background: rgba(18,20,30,0.96); backdrop-filter: blur(24px); border: 1px solid rgba(255,255,255,0.08); border-radius: 12px; min-width: 200px; box-shadow: 0 20px 60px rgba(0,0,0,0.7), 0 1px 0 rgba(255,255,255,0.05) inset; overflow: hidden; }
    .action-dropdown-item { display: flex; align-items: center; gap: 10px; padding: 10px 16px; font-size: 13px; font-weight: 500; color: var(--text-secondary); cursor: pointer; background: transparent; border: none; width: 100%; text-align: left; transition: all 0.15s; }
    .action-dropdown-item i { width: 16px; text-align: center; font-size: 13px; opacity: 0.8; }
    .action-dropdown-item:hover { background: rgba(255,255,255,0.05); color: var(--text-primary); }
    .action-dropdown-item:hover i { opacity: 1; }
    .action-dropdown-item.danger { color: #fb7185; }
    .action-dropdown-item.danger:hover { background: rgba(244,63,94,0.08); color: #fb7185; }
    .action-dropdown-item.success { color: #34d399; }
    .action-dropdown-item.success:hover { background: rgba(16,185,129,0.08); color: #34d399; }
    .action-dropdown-item.warning { color: #fbbf24; }
    .action-dropdown-item.warning:hover { background: rgba(245,158,11,0.08); }
    .action-dropdown-divider { height: 1px; background: rgba(255,255,255,0.05); margin: 4px 0; }

    /* ===== FORMS ===== */
    .form-group { margin-bottom: 20px; }
    .form-label { display: block; font-size: 12.5px; font-weight: 600; color: var(--text-primary); margin-bottom: 8px; opacity: 0.9; }
    .form-input, .form-select, .form-textarea {
      width: 100%; background: rgba(0, 0, 0, 0.2); border: 1px solid var(--border);
      border-radius: var(--radius-sm); padding: 11px 14px;
      color: var(--text-primary); font-size: 13.5px; font-family: inherit;
      transition: all var(--transition); outline: none;
    }
    .form-input::placeholder { color: var(--text-muted); }
    .form-input:focus, .form-select:focus, .form-textarea:focus { border-color: var(--accent); background: rgba(0, 0, 0, 0.35); box-shadow: 0 0 0 3px var(--accent-glow); }
    .form-select option { background: var(--bg-secondary); }
    .form-textarea { min-height: 90px; resize: vertical; }

    /* ===== ALERTS ===== */
    .alert { padding: 12px 16px; border-radius: var(--radius-sm); font-size: 13px; margin-bottom: 24px; display: flex; align-items: center; gap: 10px; font-weight: 500; }
    .alert-success { background: rgba(16, 185, 129, 0.08); border: 1px solid rgba(16, 185, 129, 0.15); color: var(--success); }
    .alert-error { background: rgba(244, 63, 94, 0.08); border: 1px solid rgba(244, 63, 94, 0.15); color: var(--danger); }

    /* ===== TABS ===== */
    .tabs { display: flex; gap: 8px; border-bottom: 1px solid var(--border); margin-bottom: 24px; }
    .tab-btn { padding: 12px 18px; font-size: 13px; font-weight: 600; color: var(--text-secondary); cursor: pointer; border: none; background: transparent; border-bottom: 2px solid transparent; transition: all var(--transition); display: flex; align-items: center; gap: 8px; }
    .tab-btn:hover { color: var(--text-primary); }
    .tab-btn.active { color: var(--accent); border-bottom-color: var(--accent); }

    /* ===== OVERLAYS & MODALS (FIXED STACKING) ===== */
    .backdrop-overlay { position: fixed; inset: 0; background: rgba(0, 0, 0, 0.7); backdrop-filter: blur(12px); z-index: 999; pointer-events: auto; }
    
    /* MODAL */
    .modal-container { position: fixed; inset: 0; z-index: 1000; display: flex; align-items: center; justify-content: center; padding: 20px; pointer-events: none; }
    .modal { background: var(--bg-secondary); border: 1px solid rgba(255, 255, 255, 0.08); border-radius: 20px; padding: 28px; max-width: 440px; width: 100%; box-shadow: 0 24px 64px rgba(0, 0, 0, 0.8); pointer-events: auto; transform: scale(1); transition: transform 0.3s cubic-bezier(0.2, 0.8, 0.2, 1); }
    .modal-title { font-size: 17px; font-weight: 700; color: var(--text-primary); margin-bottom: 8px; letter-spacing: -0.01em; }
    .modal-desc { font-size: 13px; color: var(--text-secondary); margin-bottom: 20px; line-height: 1.6; }
    .modal-actions { display: flex; gap: 12px; margin-top: 20px; }
    .modal-actions .btn { flex: 1; }

    /* COMMAND PALETTE */
    .palette-container { position: fixed; inset: 0; z-index: 2000; padding: 80px 20px 20px; pointer-events: none; display: flex; justify-content: center; align-items: flex-start; }
    .command-palette { width: 100%; max-width: 600px; background: rgba(20, 22, 32, 0.9); backdrop-filter: blur(24px); border: 1px solid rgba(255, 255, 255, 0.1); border-radius: 16px; overflow: hidden; box-shadow: 0 32px 80px rgba(0, 0, 0, 0.8); pointer-events: auto; }
    .palette-input-wrap { display: flex; align-items: center; gap: 14px; padding: 16px 20px; border-bottom: 1px solid rgba(255, 255, 255, 0.06); background: rgba(0, 0, 0, 0.15); }
    .palette-input-wrap i { color: var(--text-secondary); opacity: 0.7; font-size: 15px; }
    .palette-input { flex: 1; background: transparent; border: none; outline: none; font-size: 15px; color: var(--text-primary); font-family: inherit; }
    .palette-input::placeholder { color: var(--text-muted); }
    .palette-results { max-height: 380px; overflow-y: auto; padding: 6px 0; }
    .palette-result-item { display: flex; align-items: center; gap: 14px; padding: 11px 20px; cursor: pointer; transition: all 0.2s; text-decoration: none; color: var(--text-secondary); }
    .palette-result-item:hover, .palette-result-item.selected { background: rgba(255, 255, 255, 0.04); color: var(--text-primary); }
    .palette-result-icon { width: 34px; height: 34px; border-radius: 8px; background: rgba(255, 255, 255, 0.03); border: 1px solid rgba(255, 255, 255, 0.03); color: var(--text-primary); display: flex; align-items: center; justify-content: center; font-size: 13px; transition: all 0.2s; }
    .palette-result-item:hover .palette-result-icon { background: var(--accent); border-color: var(--accent); color: white; transform: scale(1.03); box-shadow: 0 4px 12px var(--accent-glow); }
    .palette-result-text { font-size: 13.5px; font-weight: 600; color: var(--text-primary); }
    .palette-result-sub { font-size: 11.5px; color: var(--text-secondary); opacity: 0.8; margin-top: 2px; }
    .palette-empty { padding: 32px; text-align: center; color: var(--text-secondary); opacity: 0.8; font-size: 13px; }

    /* ===== RESPONSIVE MOBILE ===== */
    @media (max-width: 768px) {
      .admin-sidebar { transform: translateX(-100%); }
      .admin-sidebar.open { transform: translateX(0); }
      .admin-main { margin-left: 0; }
      .stats-grid { grid-template-columns: 1fr; }
      .admin-content { padding: 20px; }
      .admin-topbar { padding: 0 20px; }
    }
  </style>
  <%- typeof extraHead !== 'undefined' ? extraHead : '' %>
  <%- typeof extraHead !== 'undefined' ? extraHead : '' %>
</head>
<body x-data="adminApp()" @keydown.ctrl.k.window.prevent="openPalette()" @keydown.escape.window="closeAllModals()" @open-otp-modal.window="openOtpModal($event.detail)">
  
  <!-- Global Backdrop -->
  <div class="backdrop-overlay" x-show="isAnyModalOpen" x-cloak x-transition.opacity @click="closeAllModals()"></div>

  <!-- ===== SIDEBAR ===== -->
  <%- include('./partials/admin-sidebar') %>

  <!-- ===== MAIN ===== -->
  <div class="admin-main">

    <!-- ===== TOPBAR ===== -->
    <%- include('./partials/admin-header') %>

    <!-- ===== PAGE CONTENT ===== -->
    <div class="admin-content">

      <!-- Alerts -->
      <script>
        document.addEventListener('DOMContentLoaded', () => {
          const EZToast = Swal.mixin({
            toast: true,
            position: 'top-end',
            showConfirmButton: false,
            timer: 3500,
            timerProgressBar: true,
            background: 'rgba(30, 41, 59, 0.95)',
            color: '#f8fafc',
            customClass: {
              popup: 'glass-card border border-light border-opacity-10'
            },
            didOpen: (toast) => {
              toast.onmouseenter = Swal.stopTimer;
              toast.onmouseleave = Swal.resumeTimer;
            }
          });

          <% const currentSuccess = (typeof flashSuccess !== 'undefined' && flashSuccess) || (typeof success !== 'undefined' && success) || null; %>
          <% const currentError = (typeof flashError !== 'undefined' && flashError) || (typeof error !== 'undefined' && error) || null; %>

          <% if (currentSuccess) { %>
            EZToast.fire({
              icon: 'success',
              title: `<%= currentSuccess %>`
            });
          <% } %>
          
          <% if (currentError) { %>
            Swal.fire({
              icon: 'error',
              title: 'Lỗi',
              text: `<%= currentError %>`,
              background: 'rgba(30, 41, 59, 0.95)',
              color: '#f8fafc',
              customClass: {
                popup: 'glass-card border border-danger border-opacity-25'
              }
            });
          <% } %>

          // Clean up URL query parameters
          if (window.history.replaceState) {
            const url = new URL(window.location.href);
            if (url.searchParams.has('success') || url.searchParams.has('error')) {
              url.searchParams.delete('success');
              url.searchParams.delete('error');
              window.history.replaceState({ path: url.href }, '', url.href);
            }
          }
        });
      </script>

      <%- body %>
    </div>
  </div>

  <!-- ===== COMMAND PALETTE ===== -->
  <%- include('./partials/admin-command-palette') %>

  <!-- ===== OTP MODAL ===== -->
  <%- include('./partials/admin-otp-modal') %>

  <script>
    function adminApp() {
      return {
        showPalette: false,
        sidebarOpen: false,
        paletteQuery: '',
        paletteResults: [],
        otpModal: { show: false, title: '', desc: '', action: '', targetId: '', targetData: {} },
        otpCode: '',
        otpReason: '',
        otpLoading: false,
        otpError: '',

        get isAnyModalOpen() {
          return this.showPalette || this.otpModal.show;
        },

        closeAllModals() {
          this.showPalette = false;
          this.otpModal.show = false;
        },

        openPalette() {
          this.closeAllModals();
          this.showPalette = true;
        },

        async searchPalette() {
          if (this.paletteQuery.length < 2) { this.paletteResults = []; return; }
          
          const normalizeSearch = (str) => {
            if (!str) return '';
            return str.toLowerCase()
              .normalize('NFD')
              .replace(/[\u0300-\u036f]/g, '')
              .replace(/đ/g, 'd')
              .replace(/y/g, 'i')
              .trim();
          };

          const queryNorm = normalizeSearch(this.paletteQuery);
          
          // 1. Search Static Dashboard Pages
          const staticPages = [
            { label: 'Dashboard Overview', sub: 'Tổng quan hệ thống', href: '/admin/overview', icon: 'fas fa-chart-line' },
            { label: 'Quản lý Thành viên', sub: 'Tìm và quản lý user', href: '/admin/users', icon: 'fas fa-users' },
            { label: 'Duyệt Người bán', sub: 'Đơn đăng ký Seller', href: '/admin/sellers', icon: 'fas fa-store' },
            { label: 'Kiểm duyệt Sản phẩm', sub: 'Phê duyệt sản phẩm mới', href: '/admin/products', icon: 'fas fa-box' },
            { label: 'Xử lý Hoàn tiền', sub: 'Phân xử khiếu nại', href: '/admin/refunds', icon: 'fas fa-rotate-left' },
            { label: 'Giám sát Bảo mật', sub: 'Audit logs & Abuse', href: '/admin/security', icon: 'fas fa-shield-halved' },
            { label: 'Cài đặt hệ thống', sub: 'Cài đặt chung, ngân hàng, chatbot', href: '/admin/settings', icon: 'fas fa-screwdriver-wrench' }
          ];

          const matchedPages = staticPages.filter(p => 
            normalizeSearch(p.label).includes(queryNorm) || 
            normalizeSearch(p.sub).includes(queryNorm)
          ).map(p => ({
            type: 'page',
            id: p.href,
            label: p.label,
            sub: p.sub,
            href: p.href,
            icon: p.icon
          }));

          this.paletteResults = matchedPages;

          // 2. Fetch Dynamic Users from DB
          try {
            const res = await fetch(`/admin/api/users?search=${encodeURIComponent(this.paletteQuery)}&format=json`);
            if (res.ok) {
              const data = await res.json();
              const matchedUsers = (data.users || []).slice(0, 6).map(u => ({
                type: 'user',
                id: u.id,
                label: u.displayName || u.email,
                sub: u.email,
                href: `/admin/users?search=${u.email}`,
                icon: 'fas fa-user'
              }));
              this.paletteResults = [...matchedPages, ...matchedUsers];
            }
          } catch(e) { 
            // Fallback to static pages only on error
          }
        },

        openOtpModal(config) {
          this.closeAllModals();
          this.otpModal = { show: true, ...config };
          this.otpCode = ''; this.otpReason = ''; this.otpError = '';
          if (window.Alpine) {
            Alpine.nextTick(() => {
              document.querySelector('[x-ref="otpInput"]')?.focus();
            });
          }
        },

        async submitOtp() {
          this.otpLoading = true; this.otpError = '';
          try {
            const body = new URLSearchParams({
              otpCode: this.otpCode,
              reason: this.otpReason,
              ...this.otpModal.targetData
            });
            const res = await fetch(this.otpModal.action, { method: 'POST', body, headers: { 'Content-Type': 'application/x-www-form-urlencoded' } });
            const data = await res.json();
            if (data.success) {
              this.otpModal.show = false;
              window.location.reload();
            } else {
              this.otpError = data.error || 'Có lỗi xảy ra.';
            }
          } catch(e) { this.otpError = 'Lỗi kết nối. Thử lại.'; }
          this.otpLoading = false;
        },
      };
    }
  </script>
  <%- typeof extraScript !== 'undefined' ? extraScript : '' %>
</body>
</html>
