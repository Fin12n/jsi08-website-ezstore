<%- include('./layout', { body: `
<div class="page-header" style="margin-bottom: 32px; display: flex; flex-direction: column; gap: 6px;">
  <div class="page-title" style="font-size: 24px; font-weight: 800; letter-spacing: -0.03em; background: linear-gradient(90deg, #ffffff, #94a3b8); -webkit-background-clip: text; -webkit-text-fill-color: transparent; display: flex; align-items: center; gap: 10px;">
    <i class="fas fa-chart-pie" style="color: var(--accent); font-size: 22px;"></i> Dashboard Tổng quan
  </div>
  <div class="page-subtitle" style="font-size: 13.5px; color: var(--text-secondary); opacity: 0.85;">Theo dõi số liệu và hoạt động hệ thống EZ Studio theo thời gian thực.</div>
</div>

<!-- STATS CARDS (Bento Style) -->
<div class="stats-grid" id="stats-grid" style="margin-bottom: 28px;">
  <div class="stat-card" style="position: relative; overflow: hidden; background: linear-gradient(135deg, rgba(25,28,48,0.7), rgba(15,17,28,0.75));">
    <div style="position: absolute; top: -20px; right: -20px; width: 80px; height: 80px; background: radial-gradient(circle, rgba(16,185,129,0.15) 0%, transparent 70%); border-radius: 50%;"></div>
    <div class="stat-icon green" style="background: rgba(16,185,129,0.1); border: 1px solid rgba(16,185,129,0.25); color: #10b981; box-shadow: 0 4px 12px rgba(16,185,129,0.15);"><i class="fas fa-coins"></i></div>
    <div>
      <div class="stat-value" id="stat-revenue" style="font-size: 20px; font-weight: 800; letter-spacing: -0.02em;">--</div>
      <div class="stat-label" style="font-size: 12px; color: var(--text-secondary); font-weight: 500; margin-top: 4px;">Tổng doanh thu</div>
    </div>
  </div>
  
  <div class="stat-card" style="position: relative; overflow: hidden; background: linear-gradient(135deg, rgba(25,28,48,0.7), rgba(15,17,28,0.75));">
    <div style="position: absolute; top: -20px; right: -20px; width: 80px; height: 80px; background: radial-gradient(circle, rgba(59,130,246,0.15) 0%, transparent 70%); border-radius: 50%;"></div>
    <div class="stat-icon blue" style="background: rgba(59,130,246,0.1); border: 1px solid rgba(59,130,246,0.25); color: #3b82f6; box-shadow: 0 4px 12px rgba(59,130,246,0.15);"><i class="fas fa-wallet"></i></div>
    <div>
      <div class="stat-value" id="stat-wallet" style="font-size: 20px; font-weight: 800; letter-spacing: -0.02em;">--</div>
      <div class="stat-label" style="font-size: 12px; color: var(--text-secondary); font-weight: 500; margin-top: 4px;">Số dư ví hệ thống</div>
    </div>
  </div>

  <div class="stat-card" style="position: relative; overflow: hidden; background: linear-gradient(135deg, rgba(25,28,48,0.7), rgba(15,17,28,0.75));">
    <div style="position: absolute; top: -20px; right: -20px; width: 80px; height: 80px; background: radial-gradient(circle, rgba(245,158,11,0.15) 0%, transparent 70%); border-radius: 50%;"></div>
    <div class="stat-icon yellow" style="background: rgba(245,158,11,0.1); border: 1px solid rgba(245,158,11,0.25); color: #f59e0b; box-shadow: 0 4px 12px rgba(245,158,11,0.15);"><i class="fas fa-user-plus"></i></div>
    <div>
      <div class="stat-value" id="stat-newusers" style="font-size: 20px; font-weight: 800; letter-spacing: -0.02em;">--</div>
      <div class="stat-label" style="font-size: 12px; color: var(--text-secondary); font-weight: 500; margin-top: 4px;">Thành viên mới hôm nay</div>
    </div>
  </div>

  <div class="stat-card" style="position: relative; overflow: hidden; background: linear-gradient(135deg, rgba(25,28,48,0.7), rgba(15,17,28,0.75));">
    <div style="position: absolute; top: -20px; right: -20px; width: 80px; height: 80px; background: radial-gradient(circle, rgba(239,68,68,0.15) 0%, transparent 70%); border-radius: 50%;"></div>
    <div class="stat-icon red" style="background: rgba(239,68,68,0.1); border: 1px solid rgba(239,68,68,0.25); color: #ef4444; box-shadow: 0 4px 12px rgba(239,68,68,0.15);"><i class="fas fa-clock"></i></div>
    <div>
      <div class="stat-value" id="stat-pending" style="font-size: 20px; font-weight: 800; letter-spacing: -0.02em;">--</div>
      <div class="stat-label" style="font-size: 12px; color: var(--text-secondary); font-weight: 500; margin-top: 4px;">Sản phẩm chờ duyệt</div>
    </div>
  </div>
</div>

<!-- CHARTS ROW (Bento Style Layout) -->
<div class="stats-grid" style="grid-template-columns: repeat(12, 1fr); gap: 20px; margin-bottom: 24px;">
  <!-- Revenue Chart (Col 1-8) -->
  <div class="card" style="grid-column: span 8; min-width: 0; background: linear-gradient(135deg, rgba(25,28,48,0.65), rgba(15,17,28,0.7));">
    <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:20px;">
      <div class="card-title" style="margin:0; font-size:15px; font-weight:700; color:var(--text-primary); display:flex; align-items:center; gap:8px;">
        <i class="fas fa-chart-line" style="color: var(--accent);"></i> Doanh Thu Hệ Thống
      </div>
      <div style="display:flex; gap:6px; background: rgba(0,0,0,0.2); padding: 4px; border-radius: 8px; border: 1px solid var(--border);" id="chart-period-btns">
        <button onclick="loadChart('day')" class="btn btn-ghost btn-sm" data-period="day" style="padding: 4px 10px; font-size:11px;">Ngày</button>
        <button onclick="loadChart('week')" class="btn btn-primary btn-sm" data-period="week" style="padding: 4px 10px; font-size:11px;">Tuần</button>
        <button onclick="loadChart('month')" class="btn btn-ghost btn-sm" data-period="month" style="padding: 4px 10px; font-size:11px;">Tháng</button>
      </div>
    </div>
    <div style="position:relative;height:280px; width: 100%;">
      <canvas id="revenueChart"></canvas>
    </div>
  </div>

  <!-- Activity Feed (Col 9-12) -->
  <div class="card" style="grid-column: span 4; display:flex; flex-direction:column; background: linear-gradient(135deg, rgba(25,28,48,0.65), rgba(15,17,28,0.7));">
    <div class="card-title" style="font-size:15px; font-weight:700; color:var(--text-primary); margin-bottom:16px; display:flex; align-items:center; gap:8px;">
      <i class="fas fa-clock-rotate-left" style="color: var(--accent);"></i> Hoạt động Gần đây
    </div>
    <div id="activity-feed" style="flex:1; overflow-y:auto; max-height:280px; padding-right:4px;">
      <div style="text-align:center;padding:40px 20px;color:var(--text-muted);font-size:13px;">
        <i class="fas fa-spinner fa-spin"></i> Đang tải...
      </div>
    </div>
  </div>
</div>

<!-- RECENT TRANSACTIONS TABLE -->
<div class="card" style="background: linear-gradient(135deg, rgba(25,28,48,0.65), rgba(15,17,28,0.7));">
  <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:20px;">
    <div class="card-title" style="margin:0; font-size:15px; font-weight:700; color:var(--text-primary); display:flex; align-items:center; gap:8px;">
      <i class="fas fa-receipt" style="color: var(--accent);"></i> Giao dịch Gần nhất
    </div>
    <a href="/admin/transactions" class="btn btn-ghost btn-sm" style="display:flex; align-items:center; gap:6px; font-size:12px; font-weight:600; padding: 6px 12px; border-radius: 8px;">
      Xem tất cả <i class="fas fa-arrow-right" style="font-size:10px;"></i>
    </a>
  </div>
  <div class="table-wrap">
    <table>
      <thead>
        <tr>
          <th>Mã GD</th>
          <th>Người dùng</th>
          <th>Loại</th>
          <th>Số tiền</th>
          <th>Trạng thái</th>
          <th>Thời gian</th>
        </tr>
      </thead>
      <tbody id="recent-transactions-body">
        <tr><td colspan="6" style="text-align:center;padding:40px;color:var(--text-muted);"><i class="fas fa-spinner fa-spin" style="margin-right:8px;"></i> Đang tải danh sách giao dịch...</td></tr>
      </tbody>
    </table>
  </div>
</div>
` }) %>

<script>
  let revenueChart = null;

  async function loadStats() {
    try {
      const res = await fetch('/admin/api/dashboard/stats');
      const data = await res.json();
      if (data.success) {
        const s = data.stats;
        document.getElementById('stat-revenue').textContent = formatZCoin(s.totalRevenue);
        document.getElementById('stat-wallet').textContent = formatZCoin(s.totalWalletBalance);
        document.getElementById('stat-newusers').textContent = s.newUsersToday;
        document.getElementById('stat-pending').textContent = s.pendingProducts;
      }
    } catch(e) {}
  }

  async function loadChart(period = 'week') {
    // Update active button
    document.querySelectorAll('#chart-period-btns button').forEach(b => {
      b.className = b.dataset.period === period ? 'btn btn-primary btn-sm' : 'btn btn-ghost btn-sm';
    });
    try {
      const res = await fetch(`/admin/api/dashboard/revenue-chart?period=${period}`);
      const data = await res.json();
      if (!data.success) return;
      const ctx = document.getElementById('revenueChart').getContext('2d');
      if (revenueChart) revenueChart.destroy();
      revenueChart = new Chart(ctx, {
        type: 'bar',
        data: {
          labels: data.labels,
          datasets: [
            { label: 'Ngân hàng (Sepay)', data: data.bankData, backgroundColor: 'rgba(99,102,241,0.6)', borderColor: '#6366f1', borderWidth: 1, borderRadius: 4 },
            { label: 'Thẻ cào (Card2k)', data: data.cardData, backgroundColor: 'rgba(16,185,129,0.5)', borderColor: '#10b981', borderWidth: 1, borderRadius: 4 }
          ]
        },
        options: {
          responsive: true, maintainAspectRatio: false,
          plugins: { legend: { labels: { color: '#9090b0', font: { size: 12 } } } },
          scales: {
            x: { ticks: { color: '#5a5a7a', font: { size: 11 } }, grid: { color: 'rgba(255,255,255,0.04)' } },
            y: { ticks: { color: '#5a5a7a', font: { size: 11 }, callback: v => formatZCoin(v, true) }, grid: { color: 'rgba(255,255,255,0.04)' } }
          }
        }
      });
    } catch(e) {}
  }

  async function loadActivityFeed() {
    const feed = document.getElementById('activity-feed');
    try {
      const res = await fetch('/admin/api/dashboard/activity-feed');
      const data = await res.json();
      if (data.success && data.activities.length > 0) {
        feed.innerHTML = data.activities.map(a => `
          <div style="display:flex;align-items:flex-start;gap:10px;padding:10px 0;border-bottom:1px solid rgba(255,255,255,0.04);">
            <div style="width:8px;height:8px;border-radius:50%;background:var(--accent);margin-top:5px;flex-shrink:0;"></div>
            <div>
              <div style="font-size:12.5px;color:var(--text-primary);font-weight:500;">${a.action}</div>
              <div style="font-size:11px;color:var(--text-muted);margin-top:2px;">${a.adminEmail} · ${relativeTime(a.timestamp)}</div>
            </div>
          </div>
        `).join('');
      } else {
        feed.innerHTML = '<div style="text-align:center;padding:20px;color:var(--text-muted);font-size:12px;">Chưa có hoạt động nào.</div>';
      }
    } catch(e) { feed.innerHTML = '<div style="padding:20px;color:var(--text-muted);font-size:12px;">Lỗi tải feed.</div>'; }
  }

  async function loadRecentTransactions() {
    const tbody = document.getElementById('recent-transactions-body');
    try {
      const res = await fetch('/admin/api/dashboard/recent-transactions');
      const data = await res.json();
      if (data.success && data.transactions.length > 0) {
        tbody.innerHTML = data.transactions.map(t => `
          <tr>
            <td style="font-family:monospace;font-size:12px;">#${t.id.slice(-8)}</td>
            <td>${t.userId || t.buyerId || '--'}</td>
            <td><span class="badge badge-info">${t.type || 'purchase'}</span></td>
            <td style="font-weight:600;color:var(--success);">${formatZCoin(t.totalAmount || t.amount || 0)}</td>
            <td>${statusBadge(t.status)}</td>
            <td style="font-size:12px;color:var(--text-muted);">${relativeTime(t.createdAt)}</td>
          </tr>
        `).join('');
      } else {
        tbody.innerHTML = '<tr><td colspan="6" style="text-align:center;padding:20px;color:var(--text-muted);">Chưa có giao dịch nào.</td></tr>';
      }
    } catch(e) {}
  }

  function formatZCoin(n, short = false) {
    if (!n) return '0 zCoin';
    if (short && n >= 1000) return (n/1000).toFixed(1) + 'k';
    return n.toLocaleString('vi-VN') + ' zCoin';
  }

  function relativeTime(ts) {
    if (!ts) return '--';
    const diff = Date.now() - new Date(ts).getTime();
    if (diff < 60000) return 'Vừa xong';
    if (diff < 3600000) return Math.floor(diff/60000) + ' phút trước';
    if (diff < 86400000) return Math.floor(diff/3600000) + ' giờ trước';
    return Math.floor(diff/86400000) + ' ngày trước';
  }

  function statusBadge(status) {
    const map = { completed: ['success','Hoàn thành'], pending: ['warning','Chờ xử lý'], failed: ['danger','Thất bại'], cancelled: ['muted','Đã hủy'] };
    const [cls, label] = map[status] || ['muted', status || '--'];
    return `<span class="badge badge-${cls}">${label}</span>`;
  }

  // Init
  loadStats();
  loadChart('week');
  loadActivityFeed();
  loadRecentTransactions();

  // Auto-refresh every 60s
  setInterval(() => { loadStats(); loadActivityFeed(); }, 60000);
</script>
