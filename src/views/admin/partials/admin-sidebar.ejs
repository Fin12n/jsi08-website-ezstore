<!-- Admin Sidebar Partial -->
<nav class="admin-sidebar" :class="{ 'open': sidebarOpen }" id="admin-sidebar">
  <div class="sidebar-logo" style="display: flex; align-items: center; gap: 12px; padding: 24px; border-bottom: 1px solid var(--border);">
    <div class="logo-icon" style="width: 36px; height: 36px; border-radius: 10px; background: linear-gradient(135deg, var(--accent), #8b5cf6); display: flex; align-items: center; justify-content: center; font-size: 15px; font-weight: 800; color: white; box-shadow: 0 4px 12px var(--accent-glow);">
      <i class="fas fa-cube"></i>
    </div>
    <div>
      <div class="logo-text" style="font-size: 15px; font-weight: 800; color: var(--text-primary); letter-spacing: -0.02em; background: linear-gradient(90deg, #ffffff, #cbd5e1); -webkit-background-clip: text; -webkit-text-fill-color: transparent;">EZ Studio</div>
      <div class="logo-badge" style="font-size: 8px; font-weight: 700; color: var(--accent-light); letter-spacing: 0.05em; background: var(--accent-glow); padding: 1.5px 5px; border-radius: 4px; margin-top: 2px; width: fit-content; border: 1px solid rgba(99,102,241,0.15);">PRO PANEL</div>
    </div>
  </div>

  <div class="sidebar-nav">
    <!-- Overview -->
    <div class="nav-section">
      <div class="nav-section-label">Tổng quan</div>
    </div>
    <div class="nav-item">
      <a href="/admin/overview" class="nav-link <%= activePage === 'overview' ? 'active' : '' %>">
        <i class="fas fa-chart-pie"></i> Dashboard
      </a>
    </div>

    <!-- Management -->
    <div class="nav-section" style="margin-top:12px">
      <div class="nav-section-label">Quản lý</div>
    </div>
    <div class="nav-item">
      <a href="/admin/users" class="nav-link <%= activePage === 'users' ? 'active' : '' %>">
        <i class="fas fa-user-group"></i> Thành viên
      </a>
    </div>
    <div class="nav-item">
      <a href="/admin/sellers" class="nav-link <%= activePage === 'sellers' ? 'active' : '' %>">
        <i class="fas fa-shop"></i> Người bán
        <% if (typeof pendingSellersCount !== 'undefined' && pendingSellersCount > 0) { %>
          <span class="nav-badge warning"><%= pendingSellersCount %></span>
        <% } %>
      </a>
    </div>
    <div class="nav-item">
      <a href="/admin/products" class="nav-link <%= activePage === 'products' ? 'active' : '' %>">
        <i class="fas fa-box-open"></i> Sản phẩm
        <% if (typeof pendingProductsCount !== 'undefined' && pendingProductsCount > 0) { %>
          <span class="nav-badge"><%= pendingProductsCount %></span>
        <% } %>
      </a>
    </div>
    <div class="nav-item">
      <a href="/admin/categories" class="nav-link <%= activePage === 'categories' ? 'active' : '' %>">
        <i class="fas fa-folder-tree"></i> Danh mục
      </a>
    </div>

    <!-- Finance -->
    <div class="nav-section" style="margin-top:12px">
      <div class="nav-section-label">Tài chính</div>
    </div>
    <div class="nav-item">
      <a href="/admin/transactions" class="nav-link <%= activePage === 'transactions' ? 'active' : '' %>">
        <i class="fas fa-file-invoice-dollar"></i> Giao dịch
      </a>
    </div>
    <div class="nav-item">
      <a href="/admin/refunds" class="nav-link <%= activePage === 'refunds' ? 'active' : '' %>">
        <i class="fas fa-rotate-left"></i> Hoàn tiền
        <% if (typeof pendingRefundsCount !== 'undefined' && pendingRefundsCount > 0) { %>
          <span class="nav-badge"><%= pendingRefundsCount %></span>
        <% } %>
      </a>
    </div>

    <!-- Security -->
    <div class="nav-section" style="margin-top:12px">
      <div class="nav-section-label">Bảo mật</div>
    </div>
    <div class="nav-item">
      <a href="/admin/security" class="nav-link <%= activePage === 'security' ? 'active' : '' %>">
        <i class="fas fa-shield-halved"></i> Giám sát
      </a>
    </div>

    <!-- Config -->
    <div class="nav-section" style="margin-top:12px">
      <div class="nav-section-label">Cấu hình</div>
    </div>
    <div class="nav-item">
      <a href="/admin/settings" class="nav-link <%= activePage === 'settings' ? 'active' : '' %>">
        <i class="fas fa-sliders"></i> Cài đặt hệ thống
      </a>
    </div>

    <!-- External -->
    <div class="nav-section" style="margin-top:12px">
      <div class="nav-section-label">Khác</div>
    </div>
    <div class="nav-item">
      <a href="/" class="nav-link">
        <i class="fas fa-house"></i> Về trang chủ
      </a>
    </div>
  </div>

  <!-- Admin info footer -->
  <div class="sidebar-footer">
    <div class="admin-avatar" style="background: linear-gradient(135deg, var(--accent), #8b5cf6); font-weight: 700; color: white;">
      <%= user && user.displayName ? user.displayName.charAt(0).toUpperCase() : 'A' %>
    </div>
    <div class="admin-info">
      <div class="admin-name" style="font-weight: 600; color: var(--text-primary); font-size:13px;"><%= user ? (user.displayName || user.email) : 'Admin' %></div>
      <div class="admin-role" style="font-size: 11px; color: var(--text-secondary); opacity: 0.85;">Administrator</div>
    </div>
    <a href="/logout" title="Đăng xuất" style="color: var(--text-secondary); opacity: 0.7; font-size:14px; transition: all var(--transition);" onmouseover="this.style.color='var(--danger)'; this.style.opacity='1'" onmouseout="this.style.color='var(--text-secondary)'; this.style.opacity='0.7'">
      <i class="fas fa-right-from-bracket"></i>
    </a>
  </div>
</nav>
