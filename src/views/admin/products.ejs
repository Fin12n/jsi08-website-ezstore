<%
const productsHtml = `
<div class="page-header" style="margin-bottom: 28px;">
  <div style="display:flex;align-items:center;justify-content:space-between; flex-wrap: wrap; gap: 16px;">
    <div style="display: flex; flex-direction: column; gap: 6px;">
      <div class="page-title" style="font-size: 24px; font-weight: 800; letter-spacing: -0.03em; background: linear-gradient(90deg, #ffffff, #94a3b8); -webkit-background-clip: text; -webkit-text-fill-color: transparent; display: flex; align-items: center; gap: 10px;">
        <i class="fas fa-box-open" style="color: var(--accent); font-size: 22px;"></i> Quản lý Sản phẩm
      </div>
      <div class="page-subtitle" style="font-size: 13.5px; color: var(--text-secondary); opacity: 0.85;">Kiểm duyệt sản phẩm mới, toggle hiển thị và tạo Bundle.</div>
    </div>
    <button onclick="document.getElementById('bundle-modal').style.display='flex'" class="btn btn-primary" style="display: flex; align-items: center; gap: 8px;">
      <i class="fas fa-layer-group"></i> Tạo Bundle
    </button>
  </div>
</div>

<!-- Filter Bar -->
<form method="GET" action="/admin/products" class="filter-bar" style="margin-bottom: 24px;">
  <select name="status" class="form-select" style="width:180px;" onchange="this.form.submit()">
    <option value="">Tất cả trạng thái</option>
    <option value="pending" ${typeof filters !== 'undefined' && filters.status === 'pending' ? 'selected' : ''}>⏳ Chờ duyệt</option>
    <option value="approved" ${typeof filters !== 'undefined' && filters.status === 'approved' ? 'selected' : ''}>✅ Đang hiện</option>
    <option value="hidden" ${typeof filters !== 'undefined' && filters.status === 'hidden' ? 'selected' : ''}>🚫 Đã ẩn</option>
  </select>
  <select name="category" class="form-select" style="width:200px;" onchange="this.form.submit()">
    <option value="">Tất cả danh mục</option>
    ${typeof categories !== 'undefined' ? categories.map(c => '<option value="' + c.slug + '" ' + (typeof filters !== 'undefined' && filters.category === c.slug ? 'selected' : '') + '>' + c.name + '</option>').join('') : ''}
  </select>
  <span style="margin-left:auto; font-size:13px; font-weight:600; color:var(--text-secondary); background:var(--bg-card); padding: 8px 14px; border-radius: 8px; border: 1px solid var(--border);">${typeof products !== 'undefined' ? products.length : 0} sản phẩm</span>
</form>

<!-- Products Table -->
<div class="card" style="background: linear-gradient(135deg, rgba(25,28,48,0.65), rgba(15,17,28,0.7));">
  <div class="table-wrap">
    <table class="admin-table">
      <thead>
        <tr>
          <th>Sản phẩm</th>
          <th>Người bán</th>
          <th>Giá</th>
          <th>Danh mục</th>
          <th>Trạng thái</th>
          <th style="width: 140px; text-align: center;">Thao tác</th>
        </tr>
      </thead>
      <tbody>
        ${typeof products !== 'undefined' && products.length > 0 ? products.map(p => {
          const pid = p.docId || p.id || '';
          const statusBadge = (!p.status || p.status === 'pending')
            ? '<span class="badge badge-warning" style="background:var(--warning-glow); border-color:var(--warning); color:var(--warning); font-weight:600;"><i class="fas fa-clock" style="margin-right:4px;"></i> Chờ duyệt</span>'
            : p.status === 'approved'
              ? '<span class="badge badge-success" style="background:var(--success-glow); border-color:var(--success); color:var(--success); font-weight:600;"><i class="fas fa-circle-check" style="margin-right:4px;"></i> Hiển thị</span>'
              : '<span class="badge badge-danger" style="background:var(--danger-glow); border-color:var(--danger); color:var(--danger); font-weight:600;"><i class="fas fa-ban" style="margin-right:4px;"></i> Đã ẩn</span>';
          const pendingBtns = (!p.status || p.status === 'pending')
            ? '<form action="/admin/products/' + pid + '/approve" method="POST" style="display:inline; margin:0;"><button type="submit" class="btn btn-success btn-sm" style="width:28px; height:28px; padding:0; display:flex; align-items:center; justify-content:center; border-radius:6px;" title="Duyệt sản phẩm"><i class="fas fa-check" style="font-size:11px;"></i></button></form><button onclick="rejectProduct(\'' + pid + '\')" class="btn btn-danger btn-sm" style="width:28px; height:28px; padding:0; display:flex; align-items:center; justify-content:center; border-radius:6px;" title="Từ chối sản phẩm"><i class="fas fa-times" style="font-size:11px;"></i></button>'
            : '';
          return '<tr style="transition: background var(--transition);">' +
            '<td><div style="display:flex;align-items:center;gap:12px;"><img src="' + (p.thumbnailUrl || p.imageUrl || '/imgs/logo.webp') + '" style="width:48px;height:48px;border-radius:10px;object-fit:cover;border:1px solid var(--border); box-shadow: 0 4px 10px rgba(0,0,0,0.15);" onerror="this.onerror=null;this.src=\'/imgs/logo.webp\'"><div><div style="font-weight:700;color:var(--text-primary);font-size:13.5px;max-width:260px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;letter-spacing:-0.01em;">' + (p.title || p.name || 'Không có tiêu đề') + '</div><div style="font-size:11px;color:var(--text-secondary);margin-top:2px;opacity:0.85;">ID: ' + pid.slice(-8) + '</div></div></div></td>' +
            '<td style="font-size:12.5px;color:var(--text-secondary);font-weight:500;">' + (p.sellerId || p.sellerEmail || '--') + '</td>' +
            '<td style="font-weight:700;color:var(--success);font-size:13.5px;">' + (p.salePrice || p.price || 0).toLocaleString('vi-VN') + 'đ</td>' +
            '<td><span class="badge badge-muted" style="background:rgba(255,255,255,0.05); border-color:rgba(255,255,255,0.1); color:var(--text-secondary); font-size:11px; font-weight:600;">' + (p.category || '--') + '</span></td>' +
            '<td>' + statusBadge + '</td>' +
            '<td style="text-align: center;"><div style="display:flex;gap:6px;justify-content:center;align-items:center;">' +
              pendingBtns +
              '<button onclick="toggleProduct(\'' + pid + '\', this)" class="btn btn-ghost btn-sm" style="width:28px; height:28px; padding:0; display:flex; align-items:center; justify-content:center; border-radius:6px;" title="Ẩn/Hiện sản phẩm"><i class="fas fa-eye' + (p.status === 'hidden' ? '' : '-slash') + '" style="font-size:11px;"></i></button>' +
              '<button onclick="viewVersions(\'' + pid + '\')" class="btn btn-ghost btn-sm" style="width:28px; height:28px; padding:0; display:flex; align-items:center; justify-content:center; border-radius:6px;" title="Xem phiên bản file"><i class="fas fa-code-branch" style="font-size:11px;"></i></button>' +
            '</div></td>' +
          '</tr>';
        }).join('') : '<tr><td colspan="6" style="text-align:center;padding:40px;color:var(--text-secondary);font-weight:500;">Không tìm thấy sản phẩm nào.</td></tr>'}
      </tbody>
    </table>
  </div>
</div>

<!-- Bundle Create Modal -->
<div id="bundle-modal" style="display:none;position:fixed;inset:0;background:rgba(0,0,0,0.65);z-index:1000;align-items:center;justify-content:center;padding:20px;backdrop-filter:blur(24px); transition: all 0.3s ease;">
  <div class="modal" style="max-width:500px; background: var(--bg-card); border: 1px solid var(--border); border-radius: 12px; padding: 28px; box-shadow: var(--shadow); position: relative;">
    <div class="modal-title" style="font-size: 18px; font-weight: 800; color: var(--text-primary); margin-bottom: 6px; display: flex; align-items: center; gap: 8px;">
      <i class="fas fa-layer-group" style="color: var(--accent);"></i> Tạo Bundle sản phẩm
    </div>
    <div class="modal-desc" style="font-size: 13px; color: var(--text-secondary); margin-bottom: 24px; opacity: 0.85;">Gộp nhiều sản phẩm vào một Bundle với giá ưu đãi để tăng doanh số bán hàng.</div>
    <form action="/admin/products/bundles" method="POST">
      <div class="form-group" style="margin-bottom: 18px;">
        <label class="form-label" style="font-size: 12.5px; font-weight: 600; color: var(--text-primary); margin-bottom: 6px; display: block;">Tên Bundle *</label>
        <input type="text" name="title" class="form-input" placeholder="VD: Bộ công cụ Designer Pro" required style="width: 100%;">
      </div>
      <div class="form-group" style="margin-bottom: 18px;">
        <label class="form-label" style="font-size: 12.5px; font-weight: 600; color: var(--text-primary); margin-bottom: 6px; display: block;">IDs Sản phẩm (phân cách bởi dấu phẩy) *</label>
        <input type="text" name="productIds" class="form-input" placeholder="product-id-1, product-id-2, ..." required style="width: 100%;">
      </div>
      <div class="form-group" style="margin-bottom: 24px;">
        <label class="form-label" style="font-size: 12.5px; font-weight: 600; color: var(--text-primary); margin-bottom: 6px; display: block;">Giá Bundle (VNĐ) *</label>
        <input type="number" name="bundlePrice" class="form-input" placeholder="150000" min="1000" required style="width: 100%;">
      </div>
      <div class="modal-actions" style="display: flex; gap: 10px; justify-content: flex-end;">
        <button type="button" class="btn btn-ghost" onclick="document.getElementById('bundle-modal').style.display='none'">Hủy</button>
        <button type="submit" class="btn btn-primary" style="display: flex; align-items: center; gap: 8px;"><i class="fas fa-plus"></i> Tạo Bundle</button>
      </div>
    </form>
  </div>
</div>
`;

const extraScript = `<script>
async function toggleProduct(productId, btn) {
  const res = await fetch('/admin/products/' + productId + '/toggle', { method: 'POST' });
  const data = await res.json();
  if (data.success) {
    const icon = btn.querySelector('i');
    icon.className = data.newStatus === 'hidden' ? 'fas fa-eye' : 'fas fa-eye-slash';
  } else { alert('Lỗi: ' + data.error); }
}

function rejectProduct(productId) {
  const reason = prompt('Lý do từ chối sản phẩm:');
  if (!reason) return;
  const form = document.createElement('form');
  form.method = 'POST'; form.action = '/admin/products/' + productId + '/reject';
  const field = document.createElement('input');
  field.type = 'hidden'; field.name = 'rejectionReason'; field.value = reason;
  form.appendChild(field); document.body.appendChild(form); form.submit();
}

async function viewVersions(productId) {
  const res = await fetch('/admin/products/' + productId + '/versions');
  const data = await res.json();
  if (data.success) {
    const v = data.versions;
    if (v && v.length > 0) {
      alert('File Hash: ' + (data.currentFileHash || '--') + '\\n\\nVersions:\\n' + v.map(function(ver){ return '- v' + ver.version + ': ' + (ver.fileHash || '--'); }).join('\\n'));
    } else {
      alert('File Hash: ' + (data.currentFileHash || '--') + '\\nKhông có lịch sử phiên bản.');
    }
  }
}
<\/script>`;
%>
<%- include('./layout', { body: productsHtml, extraScript }) %>
