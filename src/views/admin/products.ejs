<%
const productsHtml = `
<div class="page-header">
  <div style="display:flex;align-items:center;justify-content:space-between;">
    <div>
      <div class="page-title">📦 Quản lý Sản phẩm</div>
      <div class="page-subtitle">Kiểm duyệt sản phẩm mới, toggle hiển thị và tạo Bundle.</div>
    </div>
    <button onclick="document.getElementById('bundle-modal').style.display='flex'" class="btn btn-primary">
      <i class="fas fa-layer-group"></i> Tạo Bundle
    </button>
  </div>
</div>

<!-- Filter Bar -->
<form method="GET" action="/admin/products" class="filter-bar">
  <select name="status" class="form-select" style="width:160px;" onchange="this.form.submit()">
    <option value="">Tất cả trạng thái</option>
    <option value="pending" ${typeof filters !== 'undefined' && filters.status === 'pending' ? 'selected' : ''}>⏳ Chờ duyệt</option>
    <option value="approved" ${typeof filters !== 'undefined' && filters.status === 'approved' ? 'selected' : ''}>✅ Đang hiện</option>
    <option value="hidden" ${typeof filters !== 'undefined' && filters.status === 'hidden' ? 'selected' : ''}>🚫 Đã ẩn</option>
  </select>
  <select name="category" class="form-select" style="width:160px;" onchange="this.form.submit()">
    <option value="">Tất cả danh mục</option>
    ${typeof categories !== 'undefined' ? categories.map(c => `<option value="${c.slug}" ${typeof filters !== 'undefined' && filters.category === c.slug ? 'selected' : ''}>${c.name}</option>`).join('') : ''}
  </select>
  <span style="margin-left:auto;font-size:13px;color:var(--text-muted);">${typeof products !== 'undefined' ? products.length : 0} sản phẩm</span>
</form>

<!-- Products Table -->
<div class="card">
  <div class="table-wrap">
    <table>
      <thead>
        <tr>
          <th>Sản phẩm</th><th>Người bán</th><th>Giá</th><th>Danh mục</th><th>Trạng thái</th><th>Thao tác</th>
        </tr>
      </thead>
      <tbody>
        ${typeof products !== 'undefined' && products.length > 0 ? products.map(p => `
          <tr>
            <td>
              <div style="display:flex;align-items:center;gap:10px;">
                <img src="${p.thumbnailUrl || p.imageUrl || '/img/no-img.png'}" style="width:44px;height:44px;border-radius:8px;object-fit:cover;border:1px solid var(--border);" onerror="this.src='/img/no-img.png'">
                <div>
                  <div style="font-weight:600;color:var(--text-primary);font-size:13px;max-width:200px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">${p.title || p.name || 'Không có tiêu đề'}</div>
                  <div style="font-size:11px;color:var(--text-muted);">ID: ${(p.docId || p.id || '').slice(-8)}</div>
                </div>
              </div>
            </td>
            <td style="font-size:12px;">${p.sellerId || p.sellerEmail || '--'}</td>
            <td style="font-weight:600;color:var(--success);">${(p.salePrice || p.price || 0).toLocaleString('vi-VN')}đ</td>
            <td><span class="badge badge-muted">${p.category || '--'}</span></td>
            <td>
              ${!p.status || p.status === 'pending'
                ? '<span class="badge badge-warning">⏳ Chờ duyệt</span>'
                : p.status === 'approved'
                  ? '<span class="badge badge-success">✅ Hiển thị</span>'
                  : '<span class="badge badge-danger">🚫 Đã ẩn</span>'
              }
            </td>
            <td>
              <div style="display:flex;gap:6px;flex-wrap:wrap;">
                ${!p.status || p.status === 'pending' ? `
                  <form action="/admin/products/${p.docId || p.id}/approve" method="POST" style="display:inline;">
                    <button type="submit" class="btn btn-success btn-sm"><i class="fas fa-check"></i></button>
                  </form>
                  <button onclick="rejectProduct('${p.docId || p.id}')" class="btn btn-danger btn-sm"><i class="fas fa-times"></i></button>
                ` : ''}
                <button onclick="toggleProduct('${p.docId || p.id}', this)" class="btn btn-ghost btn-sm">
                  <i class="fas fa-eye${p.status === 'hidden' ? '' : '-slash'}"></i>
                </button>
                <button onclick="viewVersions('${p.docId || p.id}')" class="btn btn-ghost btn-sm" title="Xem versions">
                  <i class="fas fa-code-branch"></i>
                </button>
              </div>
            </td>
          </tr>
        `).join('') : '<tr><td colspan="6" style="text-align:center;padding:30px;color:var(--text-muted);">Không tìm thấy sản phẩm nào.</td></tr>'}
      </tbody>
    </table>
  </div>
</div>

<!-- Bundle Create Modal -->
<div id="bundle-modal" style="display:none;position:fixed;inset:0;background:rgba(0,0,0,0.7);z-index:1000;align-items:center;justify-content:center;padding:20px;">
  <div class="modal" style="max-width:500px;">
    <div class="modal-title">📦 Tạo Bundle sản phẩm</div>
    <div class="modal-desc">Gộp nhiều sản phẩm vào một Bundle với giá ưu đãi.</div>
    <form action="/admin/products/bundles" method="POST">
      <div class="form-group">
        <label class="form-label">Tên Bundle *</label>
        <input type="text" name="title" class="form-input" placeholder="VD: Bộ công cụ Designer Pro" required>
      </div>
      <div class="form-group">
        <label class="form-label">IDs Sản phẩm (phân cách bởi dấu phẩy) *</label>
        <input type="text" name="productIds" class="form-input" placeholder="product-id-1, product-id-2, ..." required>
      </div>
      <div class="form-group">
        <label class="form-label">Giá Bundle (VNĐ) *</label>
        <input type="number" name="bundlePrice" class="form-input" placeholder="150000" min="1000" required>
      </div>
      <div class="modal-actions">
        <button type="button" class="btn btn-ghost" onclick="document.getElementById('bundle-modal').style.display='none'">Hủy</button>
        <button type="submit" class="btn btn-primary"><i class="fas fa-plus"></i> Tạo Bundle</button>
      </div>
    </form>
  </div>
</div>
`;
%>
<%- include('./layout', { body: productsHtml }) %>

<script>
async function toggleProduct(productId, btn) {
  const res = await fetch(`/admin/products/${productId}/toggle`, { method: 'POST' });
  const data = await res.json();
  if (data.success) {
    const icon = btn.querySelector('i');
    icon.className = data.newStatus === 'hidden' ? 'fas fa-eye' : 'fas fa-eye-slash';
  } else { alert('Lỗi: ' + data.error); }
}

function rejectProduct(productId) {
  const reason = prompt('Lý do từ chối sản phẩm:');
  if (!reason) return;
  const form = document.createElement('form');
  form.method = 'POST'; form.action = `/admin/products/${productId}/reject`;
  const field = document.createElement('input');
  field.type = 'hidden'; field.name = 'rejectionReason'; field.value = reason;
  form.appendChild(field); document.body.appendChild(form); form.submit();
}

async function viewVersions(productId) {
  const res = await fetch(`/admin/products/${productId}/versions`);
  const data = await res.json();
  if (data.success) {
    const v = data.versions;
    if (v && v.length > 0) {
      alert(`File Hash: ${data.currentFileHash || '--'}\n\nVersions:\n${v.map(ver => `- v${ver.version}: ${ver.fileHash || '--'}`).join('\n')}`);
    } else {
      alert(`File Hash: ${data.currentFileHash || '--'}\nKhông có lịch sử phiên bản.`);
    }
  }
}
</script>
