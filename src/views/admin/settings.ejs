<%- include('./layout', { body: `
<div class="page-header" style="margin-bottom: 28px; display: flex; flex-direction: column; gap: 6px;">
  <div class="page-title" style="font-size: 24px; font-weight: 800; letter-spacing: -0.03em; background: linear-gradient(90deg, #ffffff, #94a3b8); -webkit-background-clip: text; -webkit-text-fill-color: transparent; display: flex; align-items: center; gap: 10px;">
    <i class="fas fa-sliders" style="color: var(--accent); font-size: 22px;"></i> Cài đặt Hệ thống
  </div>
  <div class="page-subtitle" style="font-size: 13.5px; color: var(--text-secondary); opacity: 0.85;">Tỷ giá, ngân hàng, hoa hồng, SEO metadata và quản lý mã giảm giá.</div>
</div>

<div class="stats-grid" style="grid-template-columns: repeat(12, 1fr); gap: 20px; margin-bottom: 24px; align-items: stretch;">

  <!-- Commission Rates (Col 1-6) -->
  <div class="card" style="grid-column: span 6; background: linear-gradient(135deg, rgba(25,28,48,0.65), rgba(15,17,28,0.7));">
    <div class="card-title" style="font-size:15px; font-weight:700; color:var(--text-primary); margin-bottom:20px; display:flex; align-items:center; gap:8px;">
      <i class="fas fa-coins" style="color: var(--accent);"></i> Tỷ lệ Hoa hồng theo Hạng
    </div>
    <form action="/admin/api/settings/commission" method="POST">
      <div class="form-group" style="margin-bottom: 16px;">
        <label class="form-label" style="font-size:12.5px; font-weight:600; color:var(--text-primary); margin-bottom:6px; display:block;">Hạng Standard (%)</label>
        <input type="number" name="standardRate" class="form-input" value="${typeof settings !== 'undefined' && settings.commissionRates ? settings.commissionRates.standard : 10}" min="0" max="50" step="0.5" style="width: 100%;">
      </div>
      <div class="form-group" style="margin-bottom: 16px;">
        <label class="form-label" style="font-size:12.5px; font-weight:600; color:var(--text-primary); margin-bottom:6px; display:block;">Hạng Premium (%)</label>
        <input type="number" name="premiumRate" class="form-input" value="${typeof settings !== 'undefined' && settings.commissionRates ? settings.commissionRates.premium : 8}" min="0" max="50" step="0.5" style="width: 100%;">
      </div>
      <div class="form-group" style="margin-bottom: 24px;">
        <label class="form-label" style="font-size:12.5px; font-weight:600; color:var(--text-primary); margin-bottom:6px; display:block;">Hạng Elite (%)</label>
        <input type="number" name="eliteRate" class="form-input" value="${typeof settings !== 'undefined' && settings.commissionRates ? settings.commissionRates.elite : 5}" min="0" max="50" step="0.5" style="width: 100%;">
      </div>
      <button type="submit" class="btn btn-primary" style="width:100%; display:flex; align-items:center; justify-content:center; gap:8px;"><i class="fas fa-save"></i> Lưu tỷ lệ hoa hồng</button>
    </form>
  </div>

  <!-- SEO Metadata (Col 7-12) -->
  <div class="card" style="grid-column: span 6; background: linear-gradient(135deg, rgba(25,28,48,0.65), rgba(15,17,28,0.7));">
    <div class="card-title" style="font-size:15px; font-weight:700; color:var(--text-primary); margin-bottom:20px; display:flex; align-items:center; gap:8px;">
      <i class="fas fa-magnifying-glass" style="color: var(--accent);"></i> SEO Metadata
    </div>
    <form action="/admin/api/settings/seo" method="POST">
      <div class="form-group" style="margin-bottom: 16px;">
        <label class="form-label" style="font-size:12.5px; font-weight:600; color:var(--text-primary); margin-bottom:6px; display:block;">Meta Title</label>
        <input type="text" name="metaTitle" class="form-input" placeholder="EZ Studio - Chợ sản phẩm số..." value="${typeof settings !== 'undefined' && settings.seoMeta ? settings.seoMeta.metaTitle : ''}" style="width: 100%;">
      </div>
      <div class="form-group" style="margin-bottom: 16px;">
        <label class="form-label" style="font-size:12.5px; font-weight:600; color:var(--text-primary); margin-bottom:6px; display:block;">Meta Description</label>
        <textarea name="metaDescription" class="form-textarea" rows="3" placeholder="Mô tả ngắn về trang..." style="width:100%; min-height:80px; resize:vertical;">${typeof settings !== 'undefined' && settings.seoMeta ? settings.seoMeta.metaDescription : ''}</textarea>
      </div>
      <div class="form-group" style="margin-bottom: 24px;">
        <label class="form-label" style="font-size:12.5px; font-weight:600; color:var(--text-primary); margin-bottom:6px; display:block;">Từ khóa (cách nhau bởi dấu phẩy)</label>
        <input type="text" name="metaKeywords" class="form-input" placeholder="ez studio, mua sản phẩm số, ..." value="${typeof settings !== 'undefined' && settings.seoMeta ? settings.seoMeta.metaKeywords : ''}" style="width: 100%;">
      </div>
      <button type="submit" class="btn btn-primary" style="width:100%; display:flex; align-items:center; justify-content:center; gap:8px;"><i class="fas fa-save"></i> Lưu SEO</button>
    </form>
  </div>

  <!-- Exchange Rate + Bank Info (Col 1-6) -->
  <div class="card" style="grid-column: span 6; background: linear-gradient(135deg, rgba(25,28,48,0.65), rgba(15,17,28,0.7));">
    <div class="card-title" style="font-size:15px; font-weight:700; color:var(--text-primary); margin-bottom:20px; display:flex; align-items:center; gap:8px;">
      <i class="fas fa-building-columns" style="color: var(--accent);"></i> Tỷ giá & Ngân hàng
    </div>
    <form action="/admin/api/settings" method="POST" style="margin-bottom:20px; border-bottom: 1px solid var(--border); padding-bottom: 20px;">
      <input type="hidden" name="type" value="exchange">
      <div class="form-group" style="margin-bottom: 16px;">
        <label class="form-label" style="font-size:12.5px; font-weight:600; color:var(--text-primary); margin-bottom:6px; display:block;">Tỷ giá đổi Điểm → VNĐ</label>
        <input type="number" name="exchangeRate" class="form-input" value="${typeof settings !== 'undefined' ? (settings.exchangeRate || 1) : 1}" min="1" step="1" style="width: 100%;">
      </div>
      <button type="submit" class="btn btn-primary btn-sm" style="width:100%; display:flex; align-items:center; justify-content:center; gap:8px; padding: 8px;"><i class="fas fa-exchange-alt"></i> Cập nhật tỷ giá</button>
    </form>
    <form action="/admin/api/settings" method="POST">
      <input type="hidden" name="type" value="bank">
      <div class="form-group" style="margin-bottom: 14px;">
        <label class="form-label" style="font-size:12.5px; font-weight:600; color:var(--text-primary); margin-bottom:6px; display:block;">Ngân hàng</label>
        <input type="text" name="bankName" class="form-input" placeholder="Vietcombank, Techcombank..." value="${typeof settings !== 'undefined' && settings.bankInfo ? settings.bankInfo.bankName : ''}" style="width: 100%;">
      </div>
      <div class="form-group" style="margin-bottom: 14px;">
        <label class="form-label" style="font-size:12.5px; font-weight:600; color:var(--text-primary); margin-bottom:6px; display:block;">Tên chủ tài khoản</label>
        <input type="text" name="accountName" class="form-input" placeholder="NGUYEN VAN A" value="${typeof settings !== 'undefined' && settings.bankInfo ? settings.bankInfo.accountName : ''}" style="width: 100%;">
      </div>
      <div class="form-group" style="margin-bottom: 20px;">
        <label class="form-label" style="font-size:12.5px; font-weight:600; color:var(--text-primary); margin-bottom:6px; display:block;">Số tài khoản</label>
        <input type="text" name="accountNumber" class="form-input" placeholder="1234567890" value="${typeof settings !== 'undefined' && settings.bankInfo ? settings.bankInfo.accountNumber : ''}" style="width: 100%;">
      </div>
      <button type="submit" class="btn btn-primary btn-sm" style="width:100%; display:flex; align-items:center; justify-content:center; gap:8px; padding: 8px;"><i class="fas fa-check-double"></i> Cập nhật ngân hàng</button>
    </form>
  </div>

  <!-- Cache & Maintenance (Col 7-12) -->
  <div class="card" style="grid-column: span 6; background: linear-gradient(135deg, rgba(25,28,48,0.65), rgba(15,17,28,0.7));">
    <div class="card-title" style="font-size:15px; font-weight:700; color:var(--text-primary); margin-bottom:20px; display:flex; align-items:center; gap:8px;">
      <i class="fas fa-screwdriver-wrench" style="color: var(--accent);"></i> Cache & Bảo trì
    </div>
    <div style="font-size:13px; color:var(--text-secondary); margin-bottom:18px; line-height:1.6; opacity:0.85;">
      Làm mới cache thống kê để các số liệu trên Dashboard phản ánh dữ liệu mới nhất từ Firestore.
    </div>
    <button onclick="refreshCache()" class="btn btn-primary" style="width:100%; display:flex; align-items:center; justify-content:center; gap:8px;" id="refresh-cache-btn">
      <i class="fas fa-rotate"></i> Làm mới Cache Thống kê
    </button>
    <div id="cache-result" style="margin-top:14px; display:none;"></div>
    <div style="height:1px; background:var(--border); margin:24px 0;"></div>
    
    <!-- Banner Upload -->
    <div class="card-title" style="font-size:15px; font-weight:700; color:var(--text-primary); margin-bottom:12px; display:flex; align-items:center; gap:8px;">
      <i class="fas fa-image" style="color: var(--accent);"></i> Banner Website
    </div>
    <form action="/admin/api/settings/banner" method="POST" enctype="multipart/form-data">
      <div class="form-group" style="margin-bottom: 18px;">
        <label class="form-label" style="font-size:12.5px; font-weight:600; color:var(--text-primary); margin-bottom:6px; display:block;">Upload ảnh Banner (PNG/JPG, tối đa 2MB)</label>
        <input type="file" name="banner" class="form-input" accept="image/*" style="width: 100%;">
      </div>
      <button type="submit" class="btn btn-primary btn-sm" style="width:100%; display:flex; align-items:center; justify-content:center; gap:8px; padding: 8px;"><i class="fas fa-upload"></i> Upload Banner</button>
    </form>
  </div>
</div>

<!-- Coupons Management -->
<div class="card" style="background: linear-gradient(135deg, rgba(25,28,48,0.65), rgba(15,17,28,0.7));">
  <div style="display:flex; align-items:center; justify-content:space-between; margin-bottom:20px; flex-wrap:wrap; gap:12px;">
    <div class="card-title" style="margin:0; font-size:15px; font-weight:700; color:var(--text-primary); display:flex; align-items:center; gap:8px;">
      <i class="fas fa-tags" style="color: var(--accent);"></i> Quản lý Mã Giảm giá
    </div>
    <button onclick="document.getElementById('coupon-form').style.display=document.getElementById('coupon-form').style.display==='none'?'block':'none'" class="btn btn-primary btn-sm" style="display:flex; align-items:center; gap:6px;">
      <i class="fas fa-plus"></i> Tạo mã mới
    </button>
  </div>

  <!-- Create Coupon Form (collapsible) -->
  <div id="coupon-form" style="display:none; background: rgba(0,0,0,0.25); border-radius: 10px; padding: 20px; border: 1px solid var(--border); margin-bottom: 20px; animation: slideDown 0.25s ease;">
    <form action="/admin/api/coupons" method="POST">
      <div style="display:grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap:16px; margin-bottom: 20px;">
        <div class="form-group">
          <label class="form-label" style="font-size:12.5px; font-weight:600; color:var(--text-primary); margin-bottom:6px; display:block;">Mã coupon *</label>
          <input type="text" name="code" class="form-input" placeholder="SALE50" required style="text-transform:uppercase; width:100%;">
        </div>
        <div class="form-group">
          <label class="form-label" style="font-size:12.5px; font-weight:600; color:var(--text-primary); margin-bottom:6px; display:block;">Loại giảm</label>
          <select name="discountType" class="form-select" style="width:100%;">
            <option value="percent">Phần trăm (%)</option>
            <option value="fixed">Số tiền cố định (đ)</option>
          </select>
        </div>
        <div class="form-group">
          <label class="form-label" style="font-size:12.5px; font-weight:600; color:var(--text-primary); margin-bottom:6px; display:block;">Giá trị giảm *</label>
          <input type="number" name="discountValue" class="form-input" placeholder="10" required min="1" style="width:100%;">
        </div>
        <div class="form-group">
          <label class="form-label" style="font-size:12.5px; font-weight:600; color:var(--text-primary); margin-bottom:6px; display:block;">Giới hạn sử dụng</label>
          <input type="number" name="limit" class="form-input" placeholder="Không giới hạn" style="width:100%;">
        </div>
        <div class="form-group" style="grid-column: span 2;">
          <label class="form-label" style="font-size:12.5px; font-weight:600; color:var(--text-primary); margin-bottom:6px; display:block;">Hết hạn</label>
          <input type="date" name="expiryDate" class="form-input" style="width:100%;">
        </div>
      </div>
      <button type="submit" class="btn btn-success btn-sm" style="display:flex; align-items:center; gap:6px;"><i class="fas fa-ticket"></i> Tạo mã giảm giá</button>
    </form>
  </div>

  <!-- Coupons List -->
  <div class="table-wrap">
    <table class="admin-table">
      <thead>
        <tr>
          <th>Mã</th>
          <th>Loại</th>
          <th>Giá trị</th>
          <th>Đã dùng</th>
          <th>Hết hạn</th>
          <th style="width: 80px; text-align: center;">Thao tác</th>
        </tr>
      </thead>
      <tbody>
        ${typeof coupons !== 'undefined' && coupons.length > 0 ? coupons.map(c => `
          <tr style="transition: background var(--transition);">
            <td style="font-family:monospace; font-weight:700; color:var(--accent-light); font-size:13.5px; letter-spacing:0.02em;">${c.code}</td>
            <td><span class="badge badge-info" style="background:var(--info-glow); border-color:var(--info); color:var(--info); font-size:11px; font-weight:600;">${c.discountType === 'percent' ? 'Phần trăm' : 'Cố định'}</span></td>
            <td style="font-weight:700; color:var(--text-primary); font-size:13px;">${c.discountType === 'percent' ? c.discountValue + '%' : c.discountValue.toLocaleString('vi-VN') + 'đ'}</td>
            <td style="font-size:12.5px; color:var(--text-secondary); font-weight:500;">${c.usedCount || 0}${c.limit ? '/' + c.limit : ''}</td>
            <td style="font-size:12.5px; color:var(--text-secondary); opacity:0.9;">${c.expiryDate || 'Vô thời hạn'}</td>
            <td style="text-align: center;">
              <form action="/admin/api/coupons/${c.id}/delete" method="POST" onsubmit="return confirm('Xóa mã ${c.code}?')">
                <button type="submit" class="btn btn-danger btn-sm btn-icon" style="width:28px; height:28px; padding:0; display:flex; align-items:center; justify-content:center; border-radius:6px;" title="Xóa mã giảm giá">
                  <i class="fas fa-trash-can" style="font-size:11px;"></i>
                </button>
              </form>
            </td>
          </tr>
        `).join('') : '<tr><td colspan="6" style="text-align:center;padding:40px;color:var(--text-secondary);font-weight:500;">Chưa có mã giảm giá nào.</td></tr>'}
      </tbody>
    </table>
  </div>
</div>

<script>
async function refreshCache() {
  const btn = document.getElementById('refresh-cache-btn');
  const result = document.getElementById('cache-result');
  btn.disabled = true;
  btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Đang làm mới...';
  try {
    const res = await fetch('/admin/api/settings/refresh-cache', { method: 'POST' });
    const data = await res.json();
    result.style.display = 'block';
    result.innerHTML = \`<div class="alert \${data.success ? 'alert-success' : 'alert-error'}">\${data.success ? '✅ ' + data.message : '❌ ' + data.error}</div>\`;
  } catch(e) {
    result.style.display = 'block';
    result.innerHTML = '<div class="alert alert-error">Lỗi kết nối.</div>';
  }
  btn.disabled = false;
  btn.innerHTML = '<i class="fas fa-rotate"></i> Làm mới Cache Thống kê';
}
</script>
` }) %>
