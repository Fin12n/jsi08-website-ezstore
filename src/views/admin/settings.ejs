<%- include('./layout', { body: `
<div class="page-header">
  <div class="page-title">⚙️ Cài đặt Hệ thống</div>
  <div class="page-subtitle">Tỷ giá, ngân hàng, hoa hồng, SEO metadata và quản lý mã giảm giá.</div>
</div>

<div style="display:grid;grid-template-columns:1fr 1fr;gap:20px;margin-bottom:24px;">

  <!-- Commission Rates -->
  <div class="card">
    <div class="card-title">💰 Tỷ lệ Hoa hồng theo Hạng</div>
    <form action="/admin/api/settings/commission" method="POST">
      <div class="form-group">
        <label class="form-label">Hạng Standard (%)</label>
        <input type="number" name="standardRate" class="form-input" value="${typeof settings !== 'undefined' && settings.commissionRates ? settings.commissionRates.standard : 10}" min="0" max="50" step="0.5">
      </div>
      <div class="form-group">
        <label class="form-label">Hạng Premium (%)</label>
        <input type="number" name="premiumRate" class="form-input" value="${typeof settings !== 'undefined' && settings.commissionRates ? settings.commissionRates.premium : 8}" min="0" max="50" step="0.5">
      </div>
      <div class="form-group">
        <label class="form-label">Hạng Elite (%)</label>
        <input type="number" name="eliteRate" class="form-input" value="${typeof settings !== 'undefined' && settings.commissionRates ? settings.commissionRates.elite : 5}" min="0" max="50" step="0.5">
      </div>
      <button type="submit" class="btn btn-primary" style="width:100%;justify-content:center;"><i class="fas fa-save"></i> Lưu tỷ lệ hoa hồng</button>
    </form>
  </div>

  <!-- SEO Metadata -->
  <div class="card">
    <div class="card-title">🔍 SEO Metadata</div>
    <form action="/admin/api/settings/seo" method="POST">
      <div class="form-group">
        <label class="form-label">Meta Title</label>
        <input type="text" name="metaTitle" class="form-input" placeholder="EZ Studio - Chợ sản phẩm số..." value="${typeof settings !== 'undefined' && settings.seoMeta ? settings.seoMeta.metaTitle : ''}">
      </div>
      <div class="form-group">
        <label class="form-label">Meta Description</label>
        <textarea name="metaDescription" class="form-textarea" rows="3" placeholder="Mô tả ngắn về trang...">${typeof settings !== 'undefined' && settings.seoMeta ? settings.seoMeta.metaDescription : ''}</textarea>
      </div>
      <div class="form-group">
        <label class="form-label">Từ khóa (cách nhau bởi dấu phẩy)</label>
        <input type="text" name="metaKeywords" class="form-input" placeholder="ez studio, mua sản phẩm số, ..." value="${typeof settings !== 'undefined' && settings.seoMeta ? settings.seoMeta.metaKeywords : ''}">
      </div>
      <button type="submit" class="btn btn-primary" style="width:100%;justify-content:center;"><i class="fas fa-save"></i> Lưu SEO</button>
    </form>
  </div>

  <!-- Exchange Rate + Bank Info -->
  <div class="card">
    <div class="card-title">🏦 Tỷ giá & Ngân hàng</div>
    <form action="/admin/api/settings" method="POST" style="margin-bottom:16px;">
      <input type="hidden" name="type" value="exchange">
      <div class="form-group">
        <label class="form-label">Tỷ giá đổi Điểm → VNĐ</label>
        <input type="number" name="exchangeRate" class="form-input" value="${typeof settings !== 'undefined' ? (settings.exchangeRate || 1) : 1}" min="1" step="1">
      </div>
      <button type="submit" class="btn btn-primary btn-sm" style="width:100%;justify-content:center;"><i class="fas fa-exchange-alt"></i> Cập nhật tỷ giá</button>
    </form>
    <form action="/admin/api/settings" method="POST">
      <input type="hidden" name="type" value="bank">
      <div class="form-group">
        <label class="form-label">Ngân hàng</label>
        <input type="text" name="bankName" class="form-input" placeholder="Vietcombank, Techcombank..." value="${typeof settings !== 'undefined' && settings.bankInfo ? settings.bankInfo.bankName : ''}">
      </div>
      <div class="form-group">
        <label class="form-label">Tên chủ tài khoản</label>
        <input type="text" name="accountName" class="form-input" placeholder="NGUYEN VAN A" value="${typeof settings !== 'undefined' && settings.bankInfo ? settings.bankInfo.accountName : ''}">
      </div>
      <div class="form-group">
        <label class="form-label">Số tài khoản</label>
        <input type="text" name="accountNumber" class="form-input" placeholder="1234567890" value="${typeof settings !== 'undefined' && settings.bankInfo ? settings.bankInfo.accountNumber : ''}">
      </div>
      <button type="submit" class="btn btn-primary btn-sm" style="width:100%;justify-content:center;"><i class="fas fa-building-columns"></i> Cập nhật ngân hàng</button>
    </form>
  </div>

  <!-- Cache & Maintenance -->
  <div class="card">
    <div class="card-title">🔧 Cache & Bảo trì</div>
    <div style="font-size:13px;color:var(--text-secondary);margin-bottom:16px;line-height:1.6;">
      Làm mới cache thống kê để các số liệu trên Dashboard phản ánh dữ liệu mới nhất từ Firestore.
    </div>
    <button onclick="refreshCache()" class="btn btn-primary" style="width:100%;justify-content:center;" id="refresh-cache-btn">
      <i class="fas fa-rotate"></i> Làm mới Cache Thống kê
    </button>
    <div id="cache-result" style="margin-top:12px;display:none;"></div>
    <div style="height:1px;background:var(--border);margin:20px 0;"></div>
    <!-- Banner Upload -->
    <div class="card-title" style="margin-bottom:12px;">🖼️ Banner Website</div>
    <form action="/admin/api/settings/banner" method="POST" enctype="multipart/form-data">
      <div class="form-group">
        <label class="form-label">Upload ảnh Banner (PNG/JPG, tối đa 2MB)</label>
        <input type="file" name="banner" class="form-input" accept="image/*">
      </div>
      <button type="submit" class="btn btn-primary btn-sm" style="width:100%;justify-content:center;"><i class="fas fa-upload"></i> Upload Banner</button>
    </form>
  </div>
</div>

<!-- Coupons Management -->
<div class="card">
  <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:16px;">
    <div class="card-title" style="margin:0;">🏷️ Quản lý Mã Giảm giá</div>
    <button onclick="document.getElementById('coupon-form').style.display=document.getElementById('coupon-form').style.display==='none'?'block':'none'" class="btn btn-primary btn-sm">
      <i class="fas fa-plus"></i> Tạo mã mới
    </button>
  </div>

  <!-- Create Coupon Form (collapsible) -->
  <div id="coupon-form" style="display:none;background:var(--bg-hover);border-radius:var(--radius-sm);padding:16px;margin-bottom:16px;">
    <form action="/admin/api/coupons" method="POST">
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;">
        <div class="form-group">
          <label class="form-label">Mã coupon *</label>
          <input type="text" name="code" class="form-input" placeholder="SALE50" required style="text-transform:uppercase;">
        </div>
        <div class="form-group">
          <label class="form-label">Loại giảm</label>
          <select name="discountType" class="form-select">
            <option value="percent">Phần trăm (%)</option>
            <option value="fixed">Số tiền cố định (đ)</option>
          </select>
        </div>
        <div class="form-group">
          <label class="form-label">Giá trị giảm *</label>
          <input type="number" name="discountValue" class="form-input" placeholder="10" required min="1">
        </div>
        <div class="form-group">
          <label class="form-label">Giới hạn sử dụng</label>
          <input type="number" name="limit" class="form-input" placeholder="Không giới hạn">
        </div>
        <div class="form-group" style="grid-column:1/-1;">
          <label class="form-label">Hết hạn</label>
          <input type="date" name="expiryDate" class="form-input">
        </div>
      </div>
      <button type="submit" class="btn btn-success btn-sm"><i class="fas fa-ticket"></i> Tạo mã giảm giá</button>
    </form>
  </div>

  <!-- Coupons List -->
  <div class="table-wrap">
    <table>
      <thead>
        <tr><th>Mã</th><th>Loại</th><th>Giá trị</th><th>Đã dùng</th><th>Hết hạn</th><th>Thao tác</th></tr>
      </thead>
      <tbody>
        ${typeof coupons !== 'undefined' && coupons.length > 0 ? coupons.map(c => `
          <tr>
            <td style="font-family:monospace;font-weight:700;color:var(--accent-light);">${c.code}</td>
            <td><span class="badge badge-info">${c.discountType === 'percent' ? 'Phần trăm' : 'Cố định'}</span></td>
            <td style="font-weight:600;">${c.discountType === 'percent' ? c.discountValue + '%' : c.discountValue.toLocaleString('vi-VN') + 'đ'}</td>
            <td>${c.usedCount || 0}${c.limit ? '/' + c.limit : ''}</td>
            <td style="font-size:12px;">${c.expiryDate || 'Vô thời hạn'}</td>
            <td>
              <form action="/admin/api/coupons/${c.id}/delete" method="POST" onsubmit="return confirm('Xóa mã ${c.code}?')">
                <button type="submit" class="btn btn-danger btn-sm btn-icon"><i class="fas fa-trash"></i></button>
              </form>
            </td>
          </tr>
        `).join('') : '<tr><td colspan="6" style="text-align:center;padding:20px;color:var(--text-muted);">Chưa có mã giảm giá nào.</td></tr>'}
      </tbody>
    </table>
  </div>
</div>
` }) %>

<script>
async function refreshCache() {
  const btn = document.getElementById('refresh-cache-btn');
  const result = document.getElementById('cache-result');
  btn.disabled = true;
  btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Đang làm mới...';
  try {
    const res = await fetch('/admin/api/settings/refresh-cache', { method: 'POST' });
    const data = await res.json();
    result.style.display = 'block';
    result.innerHTML = `<div class="alert ${data.success ? 'alert-success' : 'alert-error'}">${data.success ? '✅ ' + data.message : '❌ ' + data.error}</div>`;
  } catch(e) {
    result.style.display = 'block';
    result.innerHTML = '<div class="alert alert-error">Lỗi kết nối.</div>';
  }
  btn.disabled = false;
  btn.innerHTML = '<i class="fas fa-rotate"></i> Làm mới Cache Thống kê';
}
</script>
