<%- include('../partials/header') %>
<%- include('../partials/navbar') %>

<section class="user-history-section" style="padding-top: 120px; padding-bottom: 80px; min-height: 80vh; background: radial-gradient(circle at 10% 20%, rgba(154, 91, 237, 0.03) 0%, transparent 50%);">
  <div class="container">
    <div class="row g-4">
      <!-- Sidebar -->
      <div class="col-lg-3">
        <%- include('../partials/user-sidebar') %>
      </div>

      <!-- Main Content -->
      <div class="col-lg-9">
        <!-- Success/Error Alerts -->
        <% if (locals.success) { %>
          <div class="alert bg-success bg-opacity-10 border border-success border-opacity-20 text-success alert-dismissible fade show rounded-3 mb-4 d-flex align-items-center gap-2" role="alert">
            <i class="fa-solid fa-circle-check fs-5"></i>
            <div><%= success %></div>
            <button type="button" class="btn-close btn-close-white ms-auto" data-bs-dismiss="alert" aria-label="Close" style="padding: 1.25rem;"></button>
          </div>
        <% } %>
        <% if (locals.error) { %>
          <div class="alert bg-danger bg-opacity-10 border border-danger border-opacity-20 text-danger alert-dismissible fade show rounded-3 mb-4 d-flex align-items-center gap-2" role="alert">
            <i class="fa-solid fa-circle-exclamation fs-5"></i>
            <div><%= error %></div>
            <button type="button" class="btn-close btn-close-white ms-auto" data-bs-dismiss="alert" aria-label="Close" style="padding: 1.25rem;"></button>
          </div>
        <% } %>

        <div class="d-flex justify-content-between align-items-center mb-4">
          <h3 class="text-white font-outfit mb-0 fw-bold">Lịch sử giao dịch</h3>
          <span class="badge bg-purple-glow text-purple px-3 py-2 border border-secondary border-opacity-15 font-outfit">Tổng: <%= transactions ? transactions.length : 0 %> giao dịch</span>
        </div>
        
        <div class="card glass-card overflow-hidden p-0" style="border-color: rgba(255, 255, 255, 0.05);">
          <% if (transactions && transactions.length > 0) { %>
            <div class="table-responsive">
              <table class="table table-dark table-hover mb-0 bg-transparent align-middle">
                <thead>
                  <tr class="border-secondary border-opacity-25 text-secondary small text-uppercase">
                    <th class="py-3.5 px-4 bg-transparent border-0 font-outfit">Mã GD</th>
                    <th class="py-3.5 px-4 bg-transparent border-0 font-outfit">Loại hình</th>
                    <th class="py-3.5 px-4 bg-transparent border-0 font-outfit">Số tiền</th>
                    <th class="py-3.5 px-4 bg-transparent border-0 font-outfit">Trạng thái</th>
                    <th class="py-3.5 px-4 bg-transparent border-0 font-outfit">Thời gian</th>
                  </tr>
                </thead>
                <tbody class="border-top-0">
                  <% transactions.forEach(tx => { %>
                    <tr class="border-secondary border-opacity-10" style="transition: background-color 0.2s;">
                      <td class="px-4 py-3 bg-transparent text-white font-code small"><%= tx.id.slice(0,8).toUpperCase() %></td>
                      <td class="px-4 py-3 bg-transparent">
                        <% if (tx.type === 'TOPUP') { %>
                          <span class="badge bg-success bg-opacity-15 text-success border border-success border-opacity-10 px-2 py-1.5"><i class="fa-solid fa-arrow-down me-1"></i>Nạp tiền</span>
                        <% } else if (tx.type === 'PURCHASE') { %>
                          <span class="badge bg-danger bg-opacity-15 text-danger border border-danger border-opacity-10 px-2 py-1.5"><i class="fa-solid fa-cart-shopping me-1"></i>Mua hàng</span>
                        <% } else if (tx.type === 'REFUND') { %>
                          <span class="badge bg-warning bg-opacity-15 text-warning border border-warning border-opacity-10 px-2 py-1.5"><i class="fa-solid fa-rotate-left me-1"></i>Hoàn tiền</span>
                        <% } else if (tx.type === 'EARN') { %>
                          <span class="badge bg-info bg-opacity-15 text-info border border-info border-opacity-10 px-2 py-1.5"><i class="fa-solid fa-sack-dollar me-1"></i>Bán hàng</span>
                        <% } else { %>
                          <span class="badge bg-secondary bg-opacity-15 text-secondary border border-secondary border-opacity-10 px-2 py-1.5"><i class="fa-solid fa-gamepad me-1"></i>Chơi game</span>
                        <% } %>
                        <div class="small text-secondary mt-1 opacity-75"><%= tx.description %></div>
                      </td>
                      <td class="px-4 py-3 bg-transparent font-outfit fw-bold <%= tx.amount > 0 ? 'text-success text-glow-success' : 'text-danger' %>">
                        <%= tx.amount > 0 ? '+' : '' %><%= tx.amount.toLocaleString('vi-VN') %> zCoin
                      </td>
                      <td class="px-4 py-3 bg-transparent">
                        <% if (tx.status === 'COMPLETED') { %>
                          <span class="d-flex align-items-center gap-1.5 text-success small font-outfit">
                            <i class="fa-solid fa-circle-check"></i> Thành công
                          </span>
                        <% } else if (tx.status === 'PENDING') { %>
                          <span class="d-flex align-items-center gap-1.5 text-warning small font-outfit">
                            <i class="fa-solid fa-circle-notch fa-spin"></i> Đang xử lý
                          </span>
                        <% } else { %>
                          <span class="d-flex align-items-center gap-1.5 text-danger small font-outfit">
                            <i class="fa-solid fa-circle-xmark"></i> Thất bại
                          </span>
                        <% } %>
                      </td>
                      <td class="px-4 py-3 bg-transparent text-secondary small">
                        <%= new Date(tx.createdAt).toLocaleString('vi-VN') %>
                      </td>
                    </tr>
                  <% }) %>
                </tbody>
              </table>
            </div>
          <% } else { %>
            <div class="p-5 text-center">
              <div class="bg-secondary bg-opacity-10 text-secondary rounded-circle d-flex align-items-center justify-content-center mx-auto mb-3" style="width: 70px; height: 70px;">
                <i class="fa-solid fa-money-bill-transfer fs-2"></i>
              </div>
              <h5 class="text-white font-outfit fw-bold">Chưa có giao dịch nào</h5>
              <p class="text-secondary small">Bạn chưa thực hiện bất kỳ giao dịch nạp tiền hay mua sắm nào.</p>
              <a href="/user/topup" class="btn btn-hero mt-3 px-4 font-outfit">Nạp tiền ngay</a>
            </div>
          <% } %>
        </div>

      </div>
    </div>
  </div>
</section>

<%- include('../partials/footer') %>
