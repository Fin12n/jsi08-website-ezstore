<%- include('../partials/header') %>
<%- include('../partials/navbar') %>

<section class="user-settings-section" style="padding-top: 120px; padding-bottom: 80px; min-height: 80vh; background: radial-gradient(circle at 10% 20%, rgba(154, 91, 237, 0.03) 0%, transparent 50%);">
  <div class="container">
    <div class="row g-4">
      <!-- Sidebar -->
      <div class="col-lg-3">
        <%- include('../partials/user-sidebar') %>
      </div>

      <!-- Main Content -->
      <div class="col-lg-9">
        <!-- Success/Error Alerts -->
        <% if (locals.success) { %>
          <div class="alert bg-success bg-opacity-10 border border-success border-opacity-20 text-success alert-dismissible fade show rounded-3 mb-4 d-flex align-items-center gap-2" role="alert">
            <i class="fa-solid fa-circle-check fs-5"></i>
            <div><%= success %></div>
            <button type="button" class="btn-close btn-close-white ms-auto" data-bs-dismiss="alert" aria-label="Close" style="padding: 1.25rem;"></button>
          </div>
        <% } %>
        <% if (locals.error) { %>
          <div class="alert bg-danger bg-opacity-10 border border-danger border-opacity-20 text-danger alert-dismissible fade show rounded-3 mb-4 d-flex align-items-center gap-2" role="alert">
            <i class="fa-solid fa-circle-exclamation fs-5"></i>
            <div><%= error %></div>
            <button type="button" class="btn-close btn-close-white ms-auto" data-bs-dismiss="alert" aria-label="Close" style="padding: 1.25rem;"></button>
          </div>
        <% } %>

        <h3 class="text-white font-outfit mb-4 fw-bold">Cài đặt tài khoản</h3>
        
        <!-- Profile Card -->
        <div class="card glass-card p-4 mb-4" style="border-color: rgba(255, 255, 255, 0.05); background: rgba(255, 255, 255, 0.015);">
          <h5 class="text-warning font-outfit mb-3 fw-bold border-bottom border-secondary border-opacity-15 pb-2.5">
            <i class="fa-solid fa-user-gear me-2"></i>Thông tin cá nhân
          </h5>
          <div class="row g-3">
            <div class="col-md-6">
              <label class="text-secondary small mb-1.5 font-outfit">Tên hiển thị (Username)</label>
              <div class="position-relative">
                <span class="position-absolute top-50 start-0 translate-middle-y ps-3 text-secondary opacity-50"><i class="fa-solid fa-user"></i></span>
                <input type="text" class="form-control form-glass-input ps-5" value="<%= user.username %>" readonly style="cursor: not-allowed; opacity: 0.75;">
              </div>
            </div>
            <div class="col-md-6">
              <label class="text-secondary small mb-1.5 font-outfit">Địa chỉ Email</label>
              <div class="position-relative">
                <span class="position-absolute top-50 start-0 translate-middle-y ps-3 text-secondary opacity-50"><i class="fa-solid fa-envelope"></i></span>
                <input type="email" class="form-control form-glass-input ps-5" value="<%= user.email %>" readonly style="cursor: not-allowed; opacity: 0.75;">
              </div>
            </div>
          </div>
        </div>

        <!-- Security Card (2FA) -->
        <div class="card glass-card p-4" id="security" style="border-color: rgba(255, 255, 255, 0.05); background: rgba(255, 255, 255, 0.015);">
          <h5 class="text-warning font-outfit mb-3 fw-bold border-bottom border-secondary border-opacity-15 pb-2.5">
            <i class="fa-solid fa-shield-halved me-2"></i>Bảo mật 2 lớp (2FA)
          </h5>
          
          <% if (user.isTwoFactorEnabled) { %>
            <div class="alert bg-success bg-opacity-10 border border-success border-opacity-20 text-success d-flex align-items-center gap-3 p-3 rounded-3 mb-3">
              <div class="bg-success bg-opacity-25 rounded-circle p-2.5 d-flex align-items-center justify-content-center" style="width: 50px; height: 50px; box-shadow: 0 0 15px rgba(46, 204, 113, 0.3);">
                <i class="fa-solid fa-shield-check fs-4"></i>
              </div>
              <div>
                <strong class="font-outfit fs-6 text-glow-success">Bảo mật hai lớp đang HOẠT ĐỘNG</strong><br>
                <span class="small opacity-75">Tài khoản và số dư ví của bạn đang được bảo vệ bởi mã OTP.</span>
              </div>
            </div>
            
            <form action="/user/settings/2fa/disable" method="POST" onsubmit="return confirm('Bạn có chắc chắn muốn tắt 2FA? Tài khoản của bạn sẽ giảm mức độ bảo mật.');">
              <button type="submit" class="btn btn-outline-danger px-4 py-2 font-outfit">
                <i class="fa-solid fa-shield-xmark me-2"></i> Tắt xác minh 2 lớp
              </button>
            </form>
          <% } else { %>
            <p class="text-secondary small mb-4">Kích hoạt bảo mật 2 bước để yêu cầu nhập mã OTP từ ứng dụng điện thoại (Google Authenticator hoặc Authy) mỗi khi bạn thực hiện các giao dịch quan trọng hoặc đăng nhập hệ thống.</p>
            
            <% if (qrCodeUrl) { %>
              <div class="p-4 bg-dark bg-opacity-50 rounded-4 border border-secondary border-opacity-15">
                <div class="row g-4 align-items-center">
                  <!-- QR Code Container -->
                  <div class="col-md-5 text-center">
                    <span class="badge bg-warning bg-opacity-15 text-warning font-outfit px-3 py-1.5 mb-3 border border-warning border-opacity-10">BƯỚC 1</span>
                    <p class="text-white small mb-3">Quét mã QR bằng ứng dụng Authenticator</p>
                    <div class="bg-white p-3 rounded-4 d-inline-block shadow-lg border border-light border-opacity-10">
                      <img src="<%= qrCodeUrl %>" alt="2FA QR Code" class="img-fluid" style="max-width: 170px;">
                    </div>
                  </div>
                  
                  <!-- Verification Form Container -->
                  <div class="col-md-7">
                    <span class="badge bg-warning bg-opacity-15 text-warning font-outfit px-3 py-1.5 mb-3 border border-warning border-opacity-10">BƯỚC 2</span>
                    <p class="text-white small mb-3">Nhập mã 6 chữ số từ ứng dụng để xác nhận bật</p>
                    
                    <form action="/user/settings/2fa/verify" method="POST">
                      <input type="hidden" name="secret" value="<%= tempSecret %>">
                      <div class="mb-3">
                        <input type="text" name="token" class="form-control form-glass-input text-center font-code tracking-widest fs-3 fw-bold" placeholder="000000" maxlength="6" required style="letter-spacing: 0.25em;">
                      </div>
                      <button type="submit" class="btn btn-hero w-100 py-2.5 font-outfit shadow-lg d-flex align-items-center justify-content-center gap-2">
                        <i class="fa-solid fa-lock text-dark"></i> Xác minh & Kích hoạt 2FA
                      </button>
                    </form>
                  </div>
                </div>
              </div>
            <% } else { %>
              <form action="/user/settings/2fa/generate" method="POST">
                <button type="submit" class="btn btn-hero px-4 py-2.5 font-outfit d-flex align-items-center gap-2 shadow-lg">
                  <i class="fa-solid fa-shield-halved text-dark"></i> Bật xác minh 2 bước
                </button>
              </form>
            <% } %>
          <% } %>
        </div>

      </div>
    </div>
  </div>
</section>

<%- include('../partials/footer') %>
