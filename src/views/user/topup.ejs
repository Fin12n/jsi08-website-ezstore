<%- include('../partials/header') %>
<%- include('../partials/navbar') %>

<section class="user-topup-section" style="padding-top: 120px; padding-bottom: 80px; min-height: 80vh; background: radial-gradient(circle at 50% 10%, rgba(154, 91, 237, 0.04) 0%, transparent 60%);">
  <div class="container">
    <!-- Back button -->
    <a href="/user/dashboard" class="btn btn-outline-light mb-4 font-outfit px-3 py-2 hover-scale-sm border-secondary border-opacity-25" style="border-radius: 8px;">
      <i class="fa-solid fa-arrow-left-long me-2"></i>Quay lại Bảng điều khiển
    </a>

    <!-- Alerts -->
    <% if (locals.success) { %>
      <div class="alert bg-success bg-opacity-10 border border-success border-opacity-20 text-success alert-dismissible fade show rounded-3 mb-4 d-flex align-items-center gap-2" role="alert">
        <i class="fa-solid fa-circle-check fs-5"></i>
        <div><%= success %></div>
        <button type="button" class="btn-close btn-close-white ms-auto" data-bs-dismiss="alert" aria-label="Close" style="padding: 1.25rem;"></button>
      </div>
    <% } %>
    <% if (locals.error) { %>
      <div class="alert bg-danger bg-opacity-10 border border-danger border-opacity-20 text-danger alert-dismissible fade show rounded-3 mb-4 d-flex align-items-center gap-2" role="alert">
        <i class="fa-solid fa-circle-exclamation fs-5"></i>
        <div><%= error %></div>
        <button type="button" class="btn-close btn-close-white ms-auto" data-bs-dismiss="alert" aria-label="Close" style="padding: 1.25rem;"></button>
      </div>
    <% } %>

    <div class="row justify-content-center">
      <div class="col-lg-9 col-xl-8">
        <div class="text-center mb-5">
          <h2 class="text-white font-outfit fw-bold tracking-tight display-6">Nạp tiền vào Ví</h2>
          <p class="text-secondary small mt-2">Hệ thống nạp tiền tự động 24/7. Hỗ trợ chuyển khoản ngân hàng và thẻ cào điện thoại.</p>
        </div>

        <!-- Payment Methods Tabs -->
        <ul class="nav nav-pills nav-fill gap-3 mb-4" id="topupTab" role="tablist">
          <li class="nav-item" role="presentation">
            <button class="nav-link active glass-card text-white py-3 font-outfit border border-secondary border-opacity-25" id="bank-tab" data-bs-toggle="tab" data-bs-target="#bank" type="button" role="tab" aria-selected="true" style="transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);">
              <i class="fa-solid fa-building-columns fs-4 d-block mb-2 text-warning"></i>
              Chuyển khoản (Sepay QR)
            </button>
          </li>
          <li class="nav-item" role="presentation">
            <button class="nav-link glass-card text-white py-3 font-outfit border border-secondary border-opacity-25" id="card-tab" data-bs-toggle="tab" data-bs-target="#card" type="button" role="tab" aria-selected="false" style="transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);">
              <i class="fa-solid fa-money-check-dollar fs-4 d-block mb-2 text-info"></i>
              Thẻ cào (Card2k)
            </button>
          </li>
        </ul>

        <!-- Tab Contents -->
        <div class="tab-content" id="topupTabContent">
          <!-- Bank Transfer Tab -->
          <div class="tab-pane fade show active" id="bank" role="tabpanel">
            <div class="card glass-card p-4">
              <div class="alert bg-warning bg-opacity-10 border border-warning border-opacity-20 text-warning mb-4 text-start small d-flex gap-2">
                <i class="fa-solid fa-triangle-exclamation mt-0.5 fs-5"></i>
                <div>
                  <strong>Chú ý quan trọng:</strong> Bạn cần nhập chính xác <strong>Nội dung chuyển khoản</strong>. Số tiền sẽ được cộng tự động sau 1-3 phút. Nếu quá thời gian chưa nhận được tiền, vui lòng liên hệ CSKH kèm biên lai chuyển khoản.
                </div>
              </div>
              
              <div class="row g-4 align-items-center">
                  <% 
                    const bankName = (locals.settings && settings.bankInfo && settings.bankInfo.bankName) || 'MBBank';
                    const accountName = (locals.settings && settings.bankInfo && settings.bankInfo.accountName) || 'NGUYEN VAN A';
                    const accountNumber = (locals.settings && settings.bankInfo && settings.bankInfo.accountNumber) || '000000000000';
                  %>
                  <!-- QR Frame -->
                  <div class="bg-white p-3 rounded-4 d-inline-block shadow-lg border border-light border-opacity-10 position-relative">
                    <img src="https://qr.sepay.vn/img?bank=<%= bankName %>&acc=<%= accountNumber %>&template=compact&amount=50000&des=NAP%20<%= user.id %>" alt="QR Code" class="img-fluid" style="max-width: 190px; border-radius: 8px;">
                    <div class="position-absolute top-100 start-50 translate-middle mt-2.5">
                      <span class="badge bg-dark text-white border border-secondary border-opacity-20 px-2.5 py-1 text-uppercase font-outfit" style="font-size: 0.65rem;">Quét Mã QR</span>
                    </div>
                  </div>
                </div>
                <div class="col-md-7 text-start ps-md-4 mt-5 mt-md-0">
                  <h5 class="text-white font-outfit mb-3 fw-bold border-bottom border-secondary border-opacity-15 pb-2">
                    <i class="fa-solid fa-qrcode me-2 text-warning"></i>Thông tin tài khoản
                  </h5>
                  
                  <div class="row g-3">
                    <div class="col-6">
                      <p class="text-secondary mb-0.5 small">Ngân hàng:</p>
                      <h6 class="text-info font-outfit mb-0 fw-semibold"><%= bankName %></h6>
                    </div>
                    <div class="col-6">
                      <p class="text-secondary mb-0.5 small">Chủ tài khoản:</p>
                      <h6 class="text-white font-outfit mb-0 fw-semibold"><%= accountName %></h6>
                    </div>
                    <div class="col-12">
                      <p class="text-secondary mb-0.5 small">Số tài khoản:</p>
                      <div class="d-flex align-items-center gap-2">
                        <h5 class="text-white font-code mb-0 fw-bold"><%= accountNumber %></h5>
                        <button class="btn btn-sm btn-outline-secondary py-1 px-2 border-opacity-25" onclick="copyText('<%= accountNumber %>', 'Số tài khoản')">
                          <i class="fa-regular fa-copy"></i>
                        </button>
                      </div>
                    </div>
                    <div class="col-12 mt-3">
                      <p class="text-secondary mb-1.5 small fw-semibold">Nội dung chuyển khoản (Bắt buộc phải ghi):</p>
                      <div class="input-group shadow-sm">
                        <input type="text" class="form-control form-glass-input text-warning fw-bold fs-5 font-code px-3" value="NAP <%= user.id.slice(0,6).toUpperCase() %>" readonly id="transferCode">
                        <button class="btn btn-hero font-outfit px-3" type="button" onclick="copyText(document.getElementById('transferCode').value, 'Nội dung chuyển khoản')">
                          <i class="fa-regular fa-copy text-dark"></i> <span class="text-dark">Copy</span>
                        </button>
                      </div>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          </div>

          <!-- Card Topup Tab -->
          <div class="tab-pane fade" id="card" role="tabpanel">
            <div class="card glass-card p-4">
              <div class="alert bg-info bg-opacity-10 border border-info border-opacity-20 text-info mb-4 small d-flex gap-2">
                <i class="fa-solid fa-circle-info mt-0.5 fs-5"></i>
                <div>
                  <strong>Thông tin chiết khấu:</strong> Nạp bằng thẻ cào điện thoại sẽ chịu mức chiết khấu gạch thẻ từ nhà mạng (~20-25%). Hệ thống khuyên khích bạn sử dụng <strong>Chuyển khoản</strong> để được nhận 100% giá trị.
                </div>
              </div>

              <form action="/user/topup/card" method="POST">
                <div class="row g-4">
                  <div class="col-md-6">
                    <label class="form-label small text-secondary font-outfit">Nhà mạng *</label>
                    <div class="position-relative">
                      <span class="position-absolute top-50 start-0 translate-middle-y ps-3 text-secondary opacity-50"><i class="fa-solid fa-network-wired"></i></span>
                      <select class="form-select form-glass-input ps-5 py-2.5" name="telco" required>
                        <option value="VIETTEL">Viettel</option>
                        <option value="VINAPHONE">Vinaphone</option>
                        <option value="MOBIFONE">Mobifone</option>
                        <option value="ZING">Zing</option>
                      </select>
                    </div>
                  </div>
                  
                  <div class="col-md-6">
                    <label class="form-label small text-secondary font-outfit">Mệnh giá thẻ *</label>
                    <div class="position-relative">
                      <span class="position-absolute top-50 start-0 translate-middle-y ps-3 text-secondary opacity-50"><i class="fa-solid fa-tags"></i></span>
                      <select class="form-select form-glass-input ps-5 py-2.5" name="amount" required>
                        <option value="10000">10,000 đ</option>
                        <option value="20000">20,000 đ</option>
                        <option value="50000">50,000 đ</option>
                        <option value="100000">100,000 đ</option>
                        <option value="200000">200,000 đ</option>
                        <option value="500000">500,000 đ</option>
                      </select>
                    </div>
                  </div>
                  
                  <div class="col-md-6">
                    <label class="form-label small text-secondary font-outfit">Mã nạp (PIN) *</label>
                    <div class="position-relative">
                      <span class="position-absolute top-50 start-0 translate-middle-y ps-3 text-secondary opacity-50"><i class="fa-solid fa-key"></i></span>
                      <input type="text" class="form-control form-glass-input ps-5 py-2.5 font-code" name="pin" placeholder="Nhập mã PIN dưới lớp cào" required autocomplete="off">
                    </div>
                  </div>
                  
                  <div class="col-md-6">
                    <label class="form-label small text-secondary font-outfit">Số Serial *</label>
                    <div class="position-relative">
                      <span class="position-absolute top-50 start-0 translate-middle-y ps-3 text-secondary opacity-50"><i class="fa-solid fa-barcode"></i></span>
                      <input type="text" class="form-control form-glass-input ps-5 py-2.5 font-code" name="serial" placeholder="Nhập số Serial in trên thẻ" required autocomplete="off">
                    </div>
                  </div>
                  
                  <div class="col-12 mt-4.5">
                    <button type="submit" class="btn btn-hero w-100 py-3 font-outfit fs-5 shadow-lg d-flex align-items-center justify-content-center gap-2">
                      <i class="fa-solid fa-paper-plane text-dark"></i> Gửi thẻ nạp
                    </button>
                  </div>
                </div>
              </form>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
function copyText(value, name) {
  navigator.clipboard.writeText(value).then(() => {
    Swal.fire({
      toast: true,
      position: 'top-end',
      icon: 'success',
      title: 'Đã sao chép ' + name,
      showConfirmButton: false,
      timer: 1500,
      background: 'rgba(20, 20, 20, 0.95)',
      color: '#fff'
    });
  });
}
</script>

<%- include('../partials/footer') %>
