<%- include('../partials/header') %>
<%- include('../partials/navbar') %>

<section class="user-library-section" style="padding-top: 120px; padding-bottom: 80px; min-height: 80vh; background: radial-gradient(circle at 10% 20%, rgba(154, 91, 237, 0.03) 0%, transparent 50%);">
  <div class="container">
    <div class="row g-4">
      <!-- Sidebar -->
      <div class="col-lg-3">
        <%- include('../partials/user-sidebar') %>
      </div>

      <!-- Main Content -->
      <div class="col-lg-9">
        <!-- Success/Error Alerts -->
        <% if (locals.success) { %>
          <div class="alert bg-success bg-opacity-10 border border-success border-opacity-20 text-success alert-dismissible fade show rounded-3 mb-4 d-flex align-items-center gap-2" role="alert">
            <i class="fa-solid fa-circle-check fs-5"></i>
            <div><%= success %></div>
            <button type="button" class="btn-close btn-close-white ms-auto" data-bs-dismiss="alert" aria-label="Close" style="padding: 1.25rem;"></button>
          </div>
        <% } %>
        <% if (locals.error) { %>
          <div class="alert bg-danger bg-opacity-10 border border-danger border-opacity-20 text-danger alert-dismissible fade show rounded-3 mb-4 d-flex align-items-center gap-2" role="alert">
            <i class="fa-solid fa-circle-exclamation fs-5"></i>
            <div><%= error %></div>
            <button type="button" class="btn-close btn-close-white ms-auto" data-bs-dismiss="alert" aria-label="Close" style="padding: 1.25rem;"></button>
          </div>
        <% } %>

        <h3 class="text-white font-outfit mb-4 fw-bold">Thư viện của tôi</h3>
        
        <div class="row g-4">
          <% if (library && library.length > 0) { %>
            <% library.forEach(item => { %>
              <div class="col-md-6 col-lg-4">
                <div class="card glass-card p-3 h-100 hover-scale-sm d-flex flex-column" style="border-color: rgba(255, 255, 255, 0.05); background: rgba(255,255,255,0.015);">
                  <div class="position-relative mb-3 rounded-3 overflow-hidden" style="height: 160px; background: rgba(0,0,0,0.2);">
                    <img src="<%= item.productImage %>" class="w-100 h-100" style="object-fit: cover;" onerror="this.onerror=null;this.src='/imgs/logo.webp'">
                    <div class="position-absolute bottom-0 start-0 w-100 p-2" style="background: linear-gradient(to top, rgba(0,0,0,0.8), transparent);">
                      <span class="text-warning small font-code"><%= item.productId.slice(0,8).toUpperCase() %></span>
                    </div>
                  </div>
                  
                  <div class="d-flex flex-column flex-grow-1">
                    <h5 class="text-white font-outfit mb-1 fw-bold tracking-tight text-truncate" title="<%= item.productTitle %>"><%= item.productTitle %></h5>
                    <p class="text-secondary small mb-4 opacity-75">
                      <i class="fa-regular fa-calendar-check me-1"></i> Mua ngày: <%= new Date(item.purchasedAt).toLocaleDateString('vi-VN') %>
                    </p>
                    
                    <div class="mt-auto">
                      <div class="d-flex gap-2">
                        <form action="/user/download" method="POST" class="flex-grow-1">
                          <input type="hidden" name="productId" value="<%= item.productId %>">
                          <button type="submit" class="btn btn-hero w-100 py-2.5 font-outfit d-flex align-items-center justify-content-center gap-1.5 shadow-lg">
                            <i class="fa-solid fa-download text-dark"></i> Tải về
                          </button>
                        </form>
                        <form action="/user/refund" method="POST" class="flex-shrink-0" onsubmit="return confirm('Bạn có chắc chắn muốn yêu cầu hoàn tiền cho sản phẩm này? Quyền truy cập tệp tin sẽ bị tạm khoá cho đến khi xử lý xong.');">
                          <input type="hidden" name="productId" value="<%= item.productId %>">
                          <button type="submit" class="btn btn-outline-danger py-2.5 px-3" title="Yêu cầu hoàn tiền">
                            <i class="fa-solid fa-rotate-left"></i>
                          </button>
                        </form>
                      </div>
                    </div>
                  </div>
                </div>
              </div>
            <% }) %>
          <% } else { %>
            <div class="col-12 text-center py-5">
              <div class="bg-secondary bg-opacity-10 text-secondary rounded-circle d-flex align-items-center justify-content-center mx-auto mb-3" style="width: 70px; height: 70px;">
                <i class="fa-solid fa-layer-group fs-2"></i>
              </div>
              <h5 class="text-white font-outfit fw-bold">Thư viện trống</h5>
              <p class="text-secondary small">Bạn chưa mua sản phẩm nào trên hệ thống của chúng tôi.</p>
              <a href="/products" class="btn btn-outline-info mt-3 px-4 font-outfit">Đến cửa hàng ngay</a>
            </div>
          <% } %>
        </div>

      </div>
    </div>
  </div>
</section>

<%- include('../partials/footer') %>
