<script>
  const EZToast = Swal.mixin({
    toast: true,
    position: 'top-end',
    showConfirmButton: false,
    timer: 3500,
    timerProgressBar: true,
    background: 'rgba(30, 41, 59, 0.95)',
    color: '#f8fafc',
    customClass: {
      popup: 'glass-card'
    },
    didOpen: (toast) => {
      toast.onmouseenter = Swal.stopTimer;
      toast.onmouseleave = Swal.resumeTimer;
    }
  });

  <% if (typeof success !== 'undefined' && success) { %>
    EZToast.fire({
      icon: 'success',
      title: `<%= success %>`
    });
  <% } %>
  
  <% if (typeof error !== 'undefined' && error) { %>
    EZToast.fire({
      icon: 'error',
      title: `<%= error %>`
    });
  <% } %>
  
  <% if (typeof warning !== 'undefined' && warning) { %>
    EZToast.fire({
      icon: 'warning',
      title: `<%= warning %>`
    });
  <% } %>

  // Premium UI/UX Confirm Delete Modal
  function confirmDelete(event, form, message) {
    event.preventDefault();
    Swal.fire({
      title: 'Xác nhận xóa',
      text: message || 'Bạn có chắc chắn muốn thực hiện hành động này?',
      icon: 'warning',
      showCancelButton: true,
      confirmButtonColor: '#ef4444',
      cancelButtonColor: '#3b82f6',
      confirmButtonText: '<i class="fa-solid fa-trash-can me-2"></i>Đồng ý xóa',
      cancelButtonText: 'Hủy bỏ',
      background: 'rgba(30, 41, 59, 0.95)',
      color: '#f8fafc',
      customClass: { popup: 'glass-card border border-danger border-opacity-25' }
    }).then((result) => {
      if (result.isConfirmed) {
        form.submit();
      }
    });
  }
</script>
