            <i class="fa-solid fa-box-open me-1"></i> <%= __('products') %>
          </a>
        </li>
        <!-- Khám phá Dropdown -->
        <li class="nav-item dropdown">
          <a class="nav-link dropdown-toggle nav-link-custom" href="#" id="exploreDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">
            <i class="fa-solid fa-compass me-1"></i> <%= __('explore') %>
          </a>
          <ul class="dropdown-menu glass-dropdown shadow-lg border-0" aria-labelledby="exploreDropdown">
            <li><a class="dropdown-item py-2" href="/services"><i class="fa-solid fa-wrench text-secondary me-2"></i><%= __('services') %></a></li>
            <li><a class="dropdown-item py-2" href="/user/spin"><i class="fa-solid fa-rotate text-warning me-2"></i><%= __('spin') %></a></li>
            <li><a class="dropdown-item py-2" href="/leaderboard"><i class="fa-solid fa-trophy text-info me-2"></i><%= __('leaderboard') %></a></li>
            <li><hr class="dropdown-divider border-secondary border-opacity-25"></li>
            <li><a class="dropdown-item py-2" href="/#about"><i class="fa-solid fa-info-circle text-secondary me-2"></i><%= __('about') %></a></li>
            <li><a class="dropdown-item py-2" href="/#contact"><i class="fa-solid fa-phone text-secondary me-2"></i><%= __('contact') %></a></li>
            <li><a class="dropdown-item py-2" href="/#partner-ls"><i class="fa-solid fa-users text-secondary me-2"></i><%= __('partners') %></a></li>
          </ul>
        </li>
      </ul>

      <ul class="navbar-nav ms-auto align-items-center">
        <!-- Language Selector -->
        <li class="nav-item dropdown me-3 my-2 my-lg-0">
          <a class="nav-link dropdown-toggle nav-link-custom d-flex align-items-center gap-1" href="#" id="langDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">
