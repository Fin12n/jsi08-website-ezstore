<!DOCTYPE html>
<html lang="vi">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %> - EZ Studio Admin</title>
  <link rel="icon" type="image/x-icon" href="/imgs/logo.webp">
  
  <!-- Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Outfit:wght@400;500;600;700;800&family=Fira+Code&display=swap" rel="stylesheet">
  
  <!-- CSS -->
  <link href="https://cdnjs.cloudflare.com/ajax/libs/bootstrap/5.3.2/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css"> <!-- Keep base styles if needed -->
  <link rel="stylesheet" href="/css/admin.css">
  
  <!-- SweetAlert2 -->
  <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

  <!-- Chart.js for Overview -->
  <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
</head>
<body class="admin-body">

<%- include('admin-sidebar') %>

<div class="admin-main">
  <!-- Top Header Profile Area -->
  <div class="admin-header">
    <h1 class="admin-title"><%= title.split(' - ')[0] %></h1>
    <div class="admin-user-profile glass-card">
      <div class="text-end d-none d-md-block">
        <div class="admin-user-name"><%= user ? user.username : 'Admin' %></div>
        <div class="admin-user-role">Administrator</div>
      </div>
      <div class="admin-avatar-wrapper">
        <img src="https://ui-avatars.com/api/?name=<%= user ? user.username : 'A' %>&background=3b82f6&color=fff&bold=true" alt="Profile">
        <span class="admin-status-dot"></span>
      </div>
    </div>
  </div>

  <!-- Notifications handled globally via SweetAlert2 Toast -->
