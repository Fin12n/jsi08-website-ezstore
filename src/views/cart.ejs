<%- include('partials/header') %>
<%- include('partials/navbar') %>

<section class="products-section pb-5" style="padding-top: 120px; min-height: 80vh;">
  <div class="container">
    <div class="d-flex align-items-center mb-4 section-title-container">
      <h2 class="section-title text-white mb-0"><i class="fa-solid fa-cart-shopping me-2"></i>Giỏ hàng của bạn</h2>
    </div>

    <div class="row g-4">
      <!-- Cart Items List -->
      <div class="col-lg-8">
        <div class="card glass-card p-4">
          <% if (locals.cart && cart.length > 0) { %>
            <div class="table-responsive">
              <table class="table table-hover align-middle">
                <thead>
                  <tr>
                    <th>Sản phẩm</th>
                    <th>Đơn giá</th>
                    <th class="text-end">Thao tác</th>
                  </tr>
                </thead>
                <tbody>
                  <% cart.forEach(item => { %>
                  <tr>
                    <td>
                      <div class="d-flex align-items-center gap-3">
                        <img src="<%= item.image %>" alt="<%= item.title %>" class="rounded border border-secondary border-opacity-25" style="width: 60px; height: 60px; object-fit: cover;" onerror="this.onerror=null;this.src='/imgs/logo.webp'">
                        <span class="font-outfit fw-bold text-white"><%= item.title %></span>
                      </div>
                    </td>
                    <td><span class="text-success fw-bold"><%= item.price %></span></td>
                    <td class="text-end">
                      <form action="/cart/remove" method="POST" class="d-inline">
                        <input type="hidden" name="productId" value="<%= item.id %>">
                        <button type="submit" class="btn btn-sm btn-outline-danger" style="background: rgba(220,53,69,0.1); border-radius: 8px;">
                          <i class="fa-solid fa-trash"></i>
                        </button>
                      </form>
                    </td>
                  </tr>
                  <% }) %>
                </tbody>
              </table>
            </div>
          <% } else { %>
            <div class="text-center py-5">
              <i class="fa-solid fa-cart-arrow-down fs-1 text-secondary mb-3"></i>
              <p class="text-muted fs-5">Giỏ hàng của bạn đang trống.</p>
              <a href="/products" class="btn btn-outline-primary mt-2 font-outfit" style="border-radius: 30px;">Khám phá sản phẩm</a>
            </div>
          <% } %>
        </div>
      </div>

      <!-- Order Summary Sidebar -->
      <div class="col-lg-4">
        <div class="card glass-card p-4 sticky-top" style="top: 100px;">
          <h4 class="font-outfit text-white mb-4 border-bottom border-secondary border-opacity-25 pb-3">
            <i class="fa-solid fa-receipt me-2 text-primary"></i>Tóm tắt đơn hàng
          </h4>
          
          <div class="d-flex justify-content-between mb-3 text-secondary">
            <span>Tổng số lượng:</span>
            <span class="text-white fw-bold"><%= locals.cart ? cart.length : 0 %> sản phẩm</span>
          </div>

          <% if (locals.cart && cart.length > 0) { %>
            <div class="d-flex justify-content-between mb-3">
              <span class="text-secondary">Tạm tính:</span>
              <span class="text-white font-outfit fw-bold"><%= total.toLocaleString('vi-VN') %> zCoin</span>
            </div>
            
            <div class="d-flex justify-content-between mb-4">
              <span class="text-secondary">Thuế (0%):</span>
              <span class="text-white font-outfit fw-bold">0 zCoin</span>
            </div>
            
            <hr class="border-secondary opacity-25">
            
            <div class="d-flex justify-content-between mb-4 align-items-end">
              <span class="text-white fs-5">Tổng thanh toán:</span>
              <span class="text-success font-outfit fw-bold fs-3"><%= total.toLocaleString('vi-VN') %> zCoin</span>
            </div>
            
            <form action="/checkout" method="POST" class="mb-3">
              <button type="submit" class="btn btn-hero w-100 py-3 font-outfit fs-5" style="border-radius: 12px;">
                <i class="fa-solid fa-money-check-dollar me-2"></i>Thanh toán bằng Ví
              </button>
            </form>
            
            <div class="d-grid">
              <button class="btn btn-outline-warning font-outfit py-3" style="border-color: #f39c12; color: #f39c12; border-radius: 12px;" onclick="showZCoinAlert()">
                <i class="fa-solid fa-coins me-2"></i>Thanh toán bằng ZCoin
              </button>
            </div>
          <% } %>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  function showCheckoutAlert() {
    Swal.fire({
      title: 'Thông báo',
      text: 'Vui lòng liên hệ Admin qua Discord hoặc Telegram để hoàn tất thanh toán đơn hàng này.',
      icon: 'info',
      background: 'rgba(30, 41, 59, 0.95)',
      color: '#f8fafc',
      customClass: { popup: 'glass-card border border-secondary border-opacity-25' },
      confirmButtonText: 'Đã hiểu',
      confirmButtonColor: '#3b82f6'
    });
  }

  function showZCoinAlert() {
    Swal.fire({
      title: 'Tính năng đang cập nhật',
      text: 'Tính năng thanh toán bằng ZCoin tự động đang được bảo trì.',
      icon: 'warning',
      background: 'rgba(30, 41, 59, 0.95)',
      color: '#f8fafc',
      customClass: { popup: 'glass-card border border-warning border-opacity-25' },
      confirmButtonText: 'Quay lại',
      confirmButtonColor: '#f59e0b'
    });
  }
</script>

<%- include('partials/footer') %>
