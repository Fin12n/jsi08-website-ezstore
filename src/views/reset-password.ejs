<%- include('partials/header', { bodyClass: 'body-no-nav' }) %>

<!-- Home button -->
<a href="/" class="btn btn-homeback font-outfit" id="btn-back-home">
  <i class="fa-solid fa-house me-2"></i>Trang chủ
</a>

<div class="auth-wrapper">
  <div class="card glass-card auth-card">
    <div class="text-center mb-4">
      <img src="/imgs/logo.webp" alt="Logo" width="60" height="60" class="mb-3 rounded-3" />
      <h2 class="text-white font-outfit mb-1">Đặt lại mật khẩu</h2>
      <p class="text-secondary small">Vui lòng nhập mật khẩu mới cho tài khoản của bạn</p>
    </div>

    <!-- Alerts are handled globally via SweetAlert2 Toast inside flash-messages -->

    <form action="/reset-password" method="POST" id="reset-password-form">
      <!-- Hidden inputs for verification tokens -->
      <input type="hidden" name="token" value="<%= token %>" />
      <input type="hidden" name="email" value="<%= email %>" />

      <!-- New Password -->
      <div class="mb-3">
        <label for="password" class="form-label small text-secondary">Mật khẩu mới *</label>
        <div class="position-relative password-wrapper">
          <input type="password" class="form-control form-glass-input pe-5" id="password" name="password" placeholder="Nhập mật khẩu mới (tối thiểu 6 ký tự)" required minlength="6" />
          <button type="button" class="btn btn-password-toggle position-absolute top-50 end-0 translate-middle-y border-0 text-secondary" id="togglePassword">
            <i class="fa-solid fa-eye"></i>
          </button>
        </div>
      </div>

      <!-- Confirm Password -->
      <div class="mb-4">
        <label for="confirmPassword" class="form-label small text-secondary">Xác nhận mật khẩu mới *</label>
        <div class="position-relative password-wrapper">
          <input type="password" class="form-control form-glass-input pe-5" id="confirmPassword" name="confirmPassword" placeholder="Nhập lại mật khẩu mới" required minlength="6" />
          <button type="button" class="btn btn-password-toggle position-absolute top-50 end-0 translate-middle-y border-0 text-secondary" id="toggleConfirmPassword">
            <i class="fa-solid fa-eye"></i>
          </button>
        </div>
      </div>

      <button type="submit" class="btn btn-form w-100 py-2.5 font-outfit mb-3" id="btn-reset-submit">
        Xác nhận đổi mật khẩu
      </button>

      <div class="text-center small text-secondary mt-3">
        Quay lại <a href="/login" class="text-warning fw-semibold">Đăng nhập</a>
      </div>
    </form>
  </div>
</div>

<style>
.btn-password-toggle {
  background: transparent;
  transition: all 0.3s ease;
  z-index: 5;
}
.btn-password-toggle:hover {
  color: var(--primary-color) !important;
  text-shadow: 0 0 8px rgba(52, 152, 219, 0.6);
  transform: translateY(-50%) scale(1.1);
}
.password-wrapper input:focus + .btn-password-toggle {
  color: var(--primary-color) !important;
}
</style>

<script>
document.addEventListener('DOMContentLoaded', function() {
  // Password view toggle
  function setupToggle(buttonId, inputId) {
    const toggleBtn = document.getElementById(buttonId);
    const passwordInput = document.getElementById(inputId);

    if (toggleBtn && passwordInput) {
      toggleBtn.addEventListener('click', function() {
        const type = passwordInput.getAttribute('type') === 'password' ? 'text' : 'password';
        passwordInput.setAttribute('type', type);
        
        const icon = this.querySelector('i');
        if (type === 'text') {
          icon.classList.remove('fa-eye');
          icon.classList.add('fa-eye-slash');
          icon.classList.add('text-primary');
        } else {
          icon.classList.remove('fa-eye-slash');
          icon.classList.add('fa-eye');
          icon.classList.remove('text-primary');
        }
      });
    }
  }

  setupToggle('togglePassword', 'password');
  setupToggle('toggleConfirmPassword', 'confirmPassword');

  // Client-side confirmation matching check
  const form = document.getElementById('reset-password-form');
  const password = document.getElementById('password');
  const confirmPassword = document.getElementById('confirmPassword');

  form.addEventListener('submit', function(e) {
    if (password.value !== confirmPassword.value) {
      e.preventDefault();
      Swal.fire({
        icon: 'error',
        title: 'Mật khẩu không khớp',
        text: 'Mật khẩu xác nhận không giống với mật khẩu mới. Vui lòng kiểm tra lại!',
        background: 'rgba(30, 41, 59, 0.95)',
        color: '#f8fafc',
        customClass: {
          popup: 'glass-card border border-danger border-opacity-25'
        }
      });
    }
  });
});
</script>

<%- include('partials/footer') %>
